---
const chips = [
  ['Banking', 'Banca'],
  ['Fintech', 'Fintech'],
  ['Design systems', 'Sistemas de diseño'],
  ['KYC / Onboarding', 'KYC / Onboarding'],
];

const navItems = [
  ['Work', '#work', 'Trabajo'],
  ['About', '#about', 'Sobre mi'],
  ['Writing', '#writing', 'Escritura'],
  ['Contact', '#contact', 'Contacto'],
];

const nodes = [
  {
    id: 'strategic',
    title: 'Strategic Thinking',
    titleEs: 'Pensamiento estratégico',
    x: 4,
    y: 30,
  },
  {
    id: 'interaction',
    title: 'Interaction Design',
    titleEs: 'Diseño de interacción',
    x: 44,
    y: 6,
  },
  {
    id: 'ai',
    title: 'AI Prototyping',
    titleEs: 'Prototipado con IA',
    x: 75,
    y: 27,
  },
  {
    id: 'ui',
    title: 'UI Design',
    titleEs: 'Diseño UI',
    x: 81,
    y: 52,
  },
  {
    id: 'ux',
    title: 'UX Research',
    titleEs: 'Investigación UX',
    x: 72,
    y: 72,
  },
  {
    id: 'business',
    title: 'Business Constraints',
    titleEs: 'Restricciones de negocio',
    x: 35,
    y: 79,
  },
  {
    id: 'systems',
    title: 'Systems Thinking',
    titleEs: 'Pensamiento sistémico',
    x: 3,
    y: 58,
  },
  {
    id: 'spotify',
    title: 'Spotify',
    titleEs: 'Spotify',
    x: 39,
    y: 43,
    spotify: true,
  },
];

const connections = [
  ['spotify', 'strategic'],
  ['spotify', 'interaction'],
  ['spotify', 'ai'],
  ['spotify', 'ui'],
  ['spotify', 'ux'],
  ['spotify', 'business'],
  ['spotify', 'systems'],
];
---

<section class="hero" aria-labelledby="hero-title">
  <header class="hero__nav" aria-label="Primary">
    <a class="hero__brand" href="/" aria-label="Juan Villar home">
      <img src="/images/juan-villar-headshot.jpg" alt="" width="44" height="44" decoding="async" />
      <span>Juan Villar</span>
    </a>
    <button
      class="hero__menu-toggle"
      type="button"
      aria-label="Open navigation"
      aria-expanded="false"
      aria-controls="hero-navigation-menu"
      data-menu-toggle
    >
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>
    <div class="hero__nav-group" id="hero-navigation-menu" data-mobile-menu>
      <nav class="hero__links">
        {navItems.map(([label, href, labelEs]) => (
          <a href={href} data-i18n={`nav.${label.toLowerCase()}`} data-en={label} data-es={labelEs}>
            {label}
          </a>
        ))}
      </nav>
      <div class="language-toggle" aria-label="Language">
        <button type="button" data-lang-option="en" aria-pressed="true">EN</button>
        <span aria-hidden="true">/</span>
        <button type="button" data-lang-option="es" aria-pressed="false">ES</button>
      </div>
    </div>
  </header>

  <div class="hero__content">
    <div class="hero__copy">
      <p class="hero__role" data-i18n="role">Product designer</p>
      <h1 id="hero-title" class="hero__name">
        <span data-en="HI, I'M JUAN" data-es="HOLA, SOY JUAN">HI, I'M JUAN</span>
      </h1>

      <p class="hero__headline">
        <span data-i18n="headline">
          I design products, systems, and flows where clarity and trust
          <span class="headline-mark-word">
            matter.
            <svg class="mark mark--clarity" viewBox="0 0 160 22" aria-hidden="true">
              <path d="M4 15c28-8 57-10 86-9 22 1 43 4 66 1" />
              <path d="M26 20c36-8 69-11 107-9" />
            </svg>
          </span>
        </span>
      </p>

      <p class="hero__support" data-i18n="support">
        - I partner with teams to turn complexity into simple, confident experiences.
      </p>

      <ul class="hero__chips" aria-label="Focus areas">
        {chips.map(([label, labelEs]) => (
          <li data-en={label} data-es={labelEs}>{label}</li>
        ))}
      </ul>

    </div>

    <div class="hero__map-panel" aria-label="Interactive map of Juan's design focus">
      <div class="map-heading">
        <button class="map-reset" type="button" data-reset-map aria-label="Reset map">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4.5 9.5a8 8 0 1 1 2 8.1" />
            <path d="M4.5 4.8v4.7h4.7" />
          </svg>
          <span class="screen-reader-text" data-i18n="resetMap">Reset map</span>
        </button>
      </div>

      <div class="flow-map" data-flow-map>
        <svg class="flow-map__lines" aria-hidden="true">
          {connections.map(([from, to]) => (
            <path data-connection data-from={from} data-to={to}></path>
          ))}
        </svg>

        {nodes.map((node) => (
          <article
            class:list={[
              'flow-node',
              { 'flow-node--spotify': node.spotify },
            ]}
            data-node={node.id}
            data-x={node.x}
            data-y={node.y}
            tabindex="0"
            aria-label={node.spotify ? 'Spotify currently listening module' : node.title}
            style={`--x: ${node.x}; --y: ${node.y};`}
          >
            {node.spotify ? (
              <>
                <div class="spotify-art" aria-hidden="true">
                  <span class="spotify-art__play"></span>
                </div>
                <div class="spotify-copy">
                  <p
                    class="spotify-status"
                    data-en="Currently listening"
                    data-es="Escuchando ahora"
                  >
                    Currently listening
                  </p>
                  <h2 data-en="Spotify module" data-es="Módulo de Spotify">Spotify module</h2>
                  <p
                    class="spotify-track"
                    data-en="Last played song soon"
                    data-es="Última canción pronto"
                  >
                    Last played song soon
                  </p>
                </div>
                <div class="flow-node__handle" aria-hidden="true">
                  <span></span><span></span><span></span><span></span><span></span><span></span>
                </div>
              </>
            ) : (
              <>
                <div class="flow-node__copy">
                  <h2 data-node-title data-en={node.title} data-es={node.titleEs}>{node.title}</h2>
                </div>
                <div class="flow-node__handle" aria-hidden="true">
                  <span></span><span></span><span></span><span></span><span></span><span></span>
                </div>
              </>
            )}
          </article>
        ))}

        <p class="map-instruction" data-i18n="mapLabelStart">Drag the nodes to interact.</p>
      </div>
    </div>
  </div>

  <a class="hero__scroll-cue" href="#about" aria-label="Scroll to What I do section">
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 5v14" />
      <path d="m6 13 6 6 6-6" />
    </svg>
  </a>

  <script>
    import '../scripts/hero-canvas.ts';
  </script>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    overflow: clip;
    padding: clamp(1.25rem, 2.2vw, 2.5rem);
  }

  .hero::before {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    content: '';
    background-image:
      linear-gradient(rgb(16 20 23 / 2%) 1px, transparent 1px),
      linear-gradient(90deg, rgb(16 20 23 / 2%) 1px, transparent 1px);
    background-size: 46px 46px;
    mask-image: linear-gradient(90deg, transparent 0%, black 22%, black 86%, transparent 100%);
  }

  .hero__nav {
    position: relative;
    z-index: 4;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 2.75rem;
    color: var(--color-muted);
    font-size: 0.78rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero__brand {
    display: inline-flex;
    align-items: center;
    gap: clamp(0.55rem, 1vw, 0.8rem);
    color: var(--color-ink);
    font-size: 0.86rem;
    font-weight: 850;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .hero__brand img {
    width: clamp(2.15rem, 3vw, 2.75rem);
    height: clamp(2.15rem, 3vw, 2.75rem);
    flex: 0 0 auto;
    border-radius: 999px;
    object-fit: cover;
    box-shadow: 0 0 0 1px rgb(16 20 23 / 8%);
  }

  .hero__menu-toggle {
    display: none;
    width: 2.85rem;
    height: 2.85rem;
    flex: 0 0 auto;
    place-items: center;
    border: 1px solid rgb(16 20 23 / 12%);
    border-radius: 999px;
    background: var(--color-paper);
    box-shadow: 0 0.65rem 1.75rem rgb(16 20 23 / 8%);
    cursor: pointer;
  }

  .hero__menu-toggle span {
    grid-area: 1 / 1;
    display: block;
    width: 1.1rem;
    height: 2.5px;
    border-radius: 999px;
    background: var(--color-ink);
    transition:
      opacity 180ms ease,
      transform 180ms ease;
  }

  .hero__menu-toggle span:nth-child(1) {
    transform: translateY(-5px);
  }

  .hero__menu-toggle span:nth-child(3) {
    transform: translateY(5px);
  }

  .hero__menu-toggle[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(0) rotate(45deg);
  }

  .hero__menu-toggle[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }

  .hero__menu-toggle[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(0) rotate(-45deg);
  }

  .hero__nav-group,
  .hero__links,
  .language-toggle {
    display: flex;
    align-items: center;
  }

  .hero__nav-group {
    gap: clamp(1rem, 2vw, 2rem);
  }

  .hero__links {
    gap: clamp(0.8rem, 1.6vw, 1.45rem);
  }

  .hero__links a[data-i18n='nav.writing'] {
    display: none;
  }

  .hero__links a,
  .language-toggle button,
  .hero__brand,
  .hero__menu-toggle {
    transition: color 180ms ease, transform 180ms ease;
  }

  .hero__links a:hover,
  .language-toggle button:hover,
  .hero__brand:hover {
    color: var(--color-blue);
  }

  .language-toggle {
    gap: 0.35rem;
    color: var(--color-muted);
  }

  .language-toggle button {
    min-width: 2rem;
    min-height: 2rem;
    padding: 0;
    border: 0;
    background: transparent;
    color: inherit;
    cursor: pointer;
    font: inherit;
  }

  .language-toggle button[aria-pressed='true'] {
    color: var(--color-blue);
  }

  .screen-reader-text {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .hero__content {
    display: grid;
    grid-template-columns: minmax(0, 0.58fr) minmax(27rem, 0.42fr);
    gap: clamp(2rem, 3vw, 4.2rem);
    align-items: center;
    min-height: calc(100svh - 5.25rem);
    padding-top: clamp(1.5rem, 4vw, 4rem);
  }

  .hero__copy {
    max-width: 58rem;
  }

  .hero__role {
    margin: 0 0 clamp(0.75rem, 1.5vw, 1rem);
    color: #737d88;
    font-size: clamp(0.75rem, 1vw, 1rem);
    font-weight: 520;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .hero__name {
    display: flex;
    flex-wrap: wrap;
    gap: 0.05em 0.18em;
    margin: 0 0 clamp(1rem, 2vw, 1.65rem);
    color: var(--color-blue);
    font-family: var(--font-display);
    font-size: clamp(5.25rem, 9.1vw, 10.75rem);
    font-stretch: condensed;
    font-weight: 900;
    letter-spacing: -0.045em;
    line-height: 0.82;
    white-space: nowrap;
    text-transform: uppercase;
  }

  .hero__headline {
    position: relative;
    max-width: 39rem;
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(1.65rem, 2.55vw, 3.05rem);
    font-variation-settings: 'SOFT' 55, 'WONK' 1, 'opsz' 70;
    font-weight: 720;
    letter-spacing: -0.02em;
    line-height: 1.08;
  }

  .hero__headline > span {
    position: relative;
    z-index: 1;
  }

  :global(.headline-mark-word) {
    position: relative;
    display: inline-block;
    white-space: nowrap;
  }

  :global(.mark) {
    position: absolute;
    z-index: 0;
    width: clamp(5.4rem, 12vw, 9.5rem);
    height: auto;
    overflow: visible;
  }

  :global(.mark path) {
    fill: none;
    stroke: var(--color-blue);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 4;
  }

  :global(.mark--clarity) {
    left: -0.08em;
    bottom: -0.2em;
    rotate: -3deg;
  }

  .hero__support {
    max-width: 40rem;
    margin: clamp(1.2rem, 2vw, 1.65rem) 0 0;
    color: var(--color-muted);
    font-size: clamp(1rem, 1.28vw, 1.18rem);
    font-weight: 540;
    line-height: 1.55;
  }

  .hero__chips {
    display: none;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: clamp(1.25rem, 2vw, 1.75rem) 0 0;
    padding: 0;
    list-style: none;
  }

  .hero__chips li {
    display: inline-flex;
    align-items: center;
    min-height: 2.75rem;
    padding: 0.2rem 1.05rem;
    border: 1px solid var(--color-soft);
    border-radius: 999px;
    background: rgb(255 255 255 / 58%);
    color: #29333c;
    box-shadow: 0 1px 4px rgb(17 24 39 / 4%);
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 720;
  }

  .hero__map-panel {
    position: relative;
    align-self: stretch;
    min-height: 36rem;
    padding-top: clamp(0.75rem, 2.5vh, 2rem);
  }

  .map-heading {
    position: absolute;
    top: clamp(0.25rem, 1vw, 0.75rem);
    right: 0;
    z-index: 4;
    display: flex;
    align-items: flex-start;
    justify-content: flex-end;
    gap: 1rem;
    pointer-events: none;
  }

  .map-reset {
    display: grid;
    align-items: center;
    justify-content: center;
    width: clamp(2.8rem, 4vw, 3.5rem);
    height: clamp(2.8rem, 4vw, 3.5rem);
    padding: 0;
    border: 1px solid var(--color-soft);
    border-radius: 999px;
    background: rgb(255 255 255 / 72%);
    color: var(--color-blue);
    cursor: pointer;
    pointer-events: auto;
    box-shadow: 0 12px 34px rgb(17 24 39 / 7%);
    transition: border-color 180ms ease, transform 180ms ease, box-shadow 180ms ease;
  }

  .map-reset svg {
    width: 1.7rem;
    height: 1.7rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.6;
  }

  .map-reset:hover {
    border-color: var(--color-blue);
    box-shadow: 0 18px 44px rgb(15 92 255 / 13%);
    transform: rotate(-12deg) scale(1.04);
  }

  .flow-map {
    position: relative;
    min-height: clamp(28rem, 55vh, 36rem);
    isolation: isolate;
  }

  .flow-map__lines {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
    pointer-events: none;
  }

  .flow-map__lines path {
    fill: none;
    stroke: #c5d0d8;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.35;
    transition: opacity 160ms cubic-bezier(0.23, 1, 0.32, 1), stroke 160ms cubic-bezier(0.23, 1, 0.32, 1), stroke-width 160ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .flow-map__lines path.is-active-connection {
    stroke: rgb(15 92 255 / 52%);
    stroke-width: 2.45;
  }

  .flow-map__lines path.is-dimmed {
    opacity: 0.32;
  }

  .flow-map__lines path.is-connected {
    opacity: 1;
    stroke: rgb(15 92 255 / 72%);
    stroke-width: 2.8;
  }

  .flow-node {
    --node-glow: rgb(17 24 39 / 8%);
    --node-glow-soft: rgb(17 24 39 / 5%);
    --node-interaction-glow: rgb(17 24 39 / 12%);
    --node-interaction-glow-soft: rgb(17 24 39 / 8%);
    position: absolute;
    left: calc(var(--x) * 1%);
    top: calc(var(--y) * 1%);
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.8rem;
    width: clamp(12rem, 13.4vw, 14.5rem);
    min-height: 3.9rem;
    padding: 0.82rem 0.95rem 0.78rem;
    border: 1px solid var(--color-soft);
    border-radius: 0.62rem;
    background: rgb(255 255 255 / 88%);
    box-shadow: 0 18px 50px var(--node-glow), 0 2px 8px var(--node-glow-soft);
    cursor: grab;
    touch-action: none;
    user-select: none;
    transition: border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
  }

  .flow-node:hover,
  .flow-node:focus-visible {
    border-color: #a7b4bf;
    box-shadow: 0 22px 56px var(--node-interaction-glow), 0 4px 14px var(--node-interaction-glow-soft);
    transform: translateY(-2px);
  }

  .flow-node[data-node='strategic'] {
    --node-interaction-glow: rgb(0 174 180 / 18%);
    --node-interaction-glow-soft: rgb(0 174 180 / 10%);
  }

  .flow-node[data-node='interaction'] {
    --node-interaction-glow: rgb(255 184 0 / 18%);
    --node-interaction-glow-soft: rgb(255 184 0 / 10%);
  }

  .flow-node[data-node='ai'] {
    --node-interaction-glow: rgb(255 91 128 / 16%);
    --node-interaction-glow-soft: rgb(255 91 128 / 9%);
  }

  .flow-node[data-node='ui'] {
    --node-interaction-glow: rgb(15 92 255 / 16%);
    --node-interaction-glow-soft: rgb(15 92 255 / 9%);
  }

  .flow-node[data-node='ux'] {
    --node-interaction-glow: rgb(120 95 255 / 17%);
    --node-interaction-glow-soft: rgb(120 95 255 / 9%);
  }

  .flow-node[data-node='business'] {
    --node-interaction-glow: rgb(29 185 84 / 17%);
    --node-interaction-glow-soft: rgb(29 185 84 / 9%);
  }

  .flow-node[data-node='systems'] {
    --node-interaction-glow: rgb(255 129 54 / 16%);
    --node-interaction-glow-soft: rgb(255 129 54 / 9%);
  }

  .flow-node[data-node='spotify'] {
    --node-interaction-glow: rgb(29 185 84 / 18%);
    --node-interaction-glow-soft: rgb(29 185 84 / 10%);
  }

  .flow-node.is-dragging {
    z-index: 5;
    box-shadow: 0 26px 62px var(--node-interaction-glow), 0 4px 16px var(--node-interaction-glow-soft);
    cursor: grabbing;
    transform: scale(1.025);
  }

  .flow-node--active {
    border: 2px solid var(--color-blue);
    box-shadow: 0 18px 50px var(--node-glow), 0 2px 8px var(--node-glow-soft);
  }

  .flow-node__handle {
    display: grid;
    grid-template-columns: repeat(2, 0.24rem);
    gap: 0.28rem;
    align-content: center;
    padding-top: 0.05rem;
  }

  .flow-node__handle span {
    width: 0.24rem;
    height: 0.24rem;
    border-radius: 50%;
    background: rgb(168 179 188 / 28%);
    transition: background-color 160ms cubic-bezier(0.23, 1, 0.32, 1), transform 160ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .flow-node:hover .flow-node__handle span,
  .flow-node:focus-visible .flow-node__handle span,
  .flow-node.is-dragging .flow-node__handle span {
    background: var(--color-blue);
    transform: scale(1.1);
  }

  .flow-node__copy {
    min-width: 0;
    text-align: left;
  }

  .flow-node h2 {
    margin: 0;
    color: var(--color-ink);
    font-size: clamp(0.96rem, 1.18vw, 1.22rem);
    font-weight: 850;
    letter-spacing: -0.015em;
    line-height: 1.05;
  }

  .flow-node p {
    margin: 0;
    color: #55626d;
    font-size: clamp(0.68rem, 0.78vw, 0.78rem);
    font-weight: 620;
    line-height: 1.32;
  }

  .flow-node--spotify {
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    width: clamp(18rem, 24vw, 25rem);
    min-height: 5.2rem;
    padding: 0.85rem 1rem;
    border-radius: 0.8rem;
  }

  .spotify-art {
    position: relative;
    display: grid;
    place-items: center;
    width: clamp(3rem, 4.4vw, 3.9rem);
    height: clamp(3rem, 4.4vw, 3.9rem);
    overflow: hidden;
    border-radius: 50%;
    background:
      radial-gradient(circle at 70% 25%, rgb(255 255 255 / 85%) 0 0.32rem, transparent 0.36rem),
      radial-gradient(circle at 35% 65%, #e333ff 0 0.55rem, transparent 0.6rem),
      linear-gradient(135deg, #13002f, #6117ff 42%, #15191e 72%);
    box-shadow: inset 0 0 0 1px rgb(255 255 255 / 35%);
  }

  .spotify-art::before {
    position: absolute;
    inset: 0;
    content: '';
    background:
      linear-gradient(120deg, transparent 18%, rgb(255 255 255 / 22%) 19% 21%, transparent 22%),
      linear-gradient(20deg, transparent 55%, rgb(0 0 0 / 34%) 56%);
  }

  .spotify-art__play {
    position: relative;
    z-index: 1;
    width: 0;
    height: 0;
    margin-left: 0.18rem;
    border-top: 0.58rem solid transparent;
    border-bottom: 0.58rem solid transparent;
    border-left: 0.9rem solid #ffffff;
    filter: drop-shadow(0 2px 6px rgb(0 0 0 / 26%));
  }

  .spotify-copy {
    min-width: 0;
  }

  .spotify-status {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    margin: 0 0 0.18rem;
    color: #b5c0c8;
    font-size: clamp(0.56rem, 0.72vw, 0.72rem);
    font-weight: 620;
    letter-spacing: 0.04em;
    line-height: 1;
    text-transform: uppercase;
  }

  .spotify-status::before {
    content: '🎧';
    font-size: 0.78rem;
