---
const chips = [
  ['Banking', 'Banca'],
  ['Fintech', 'Fintech'],
  ['Design systems', 'Sistemas de diseño'],
  ['KYC / Onboarding', 'KYC / Onboarding'],
];

const navItems = [
  ['Work', '#work', 'Trabajo'],
  ['About', '#about', 'Sobre mi'],
  ['Writing', '#writing', 'Escritura'],
  ['Contact', '#contact', 'Contacto'],
];

const nodes = [
  {
    id: 'flows',
    title: 'Strategic Thinking',
    titleEs: 'Pensamiento estratégico',
    body: 'Frame the problem before shaping the interface.',
    bodyEs: 'Definir el problema antes de diseñar la interfaz.',
    x: 12,
    y: 24,
    active: true,
  },
  {
    id: 'systems',
    title: 'Interaction Design',
    titleEs: 'Diseño de interacción',
    body: 'Shape behavior across states, actions, and feedback.',
    bodyEs: 'Diseñar comportamiento entre estados, acciones y feedback.',
    x: 52,
    y: 10,
  },
  {
    id: 'interfaces',
    title: 'AI Prototyping',
    titleEs: 'Prototipado con IA',
    body: 'Explore directions faster without losing judgment.',
    bodyEs: 'Explorar direcciones más rápido sin perder criterio.',
    x: 80,
    y: 24,
  },
  {
    id: 'banking',
    title: 'UI Design',
    titleEs: 'Diseño UI',
    body: 'Make flows clear, usable, and consistent.',
    bodyEs: 'Hacer los flujos claros, usables y consistentes.',
    x: 80,
    y: 46,
  },
  {
    id: 'trust',
    title: 'UX Research',
    titleEs: 'Investigación UX',
    body: 'Understand needs, constraints, and uncertainty.',
    bodyEs: 'Entender necesidades, restricciones e incertidumbre.',
    x: 78,
    y: 66,
  },
  {
    id: 'factory',
    title: 'Business Constraints',
    titleEs: 'Restricciones de negocio',
    body: 'Connect user needs with product realities.',
    bodyEs: 'Conectar necesidades de usuario con realidades del producto.',
    x: 38,
    y: 74,
  },
  {
    id: 'thinking',
    title: 'Systems Thinking',
    titleEs: 'Pensamiento sistémico',
    body: 'See how flows, rules, and teams connect.',
    bodyEs: 'Ver cómo se conectan flujos, reglas y equipos.',
    x: 12,
    y: 58,
  },
];

const connections = [
  ['flows', 'systems'],
  ['systems', 'interfaces'],
  ['interfaces', 'banking'],
  ['flows', 'thinking'],
  ['banking', 'trust'],
  ['systems', 'factory'],
  ['factory', 'trust'],
  ['thinking', 'factory'],
];
---

<section class="hero" aria-labelledby="hero-title">
  <header class="hero__nav" aria-label="Primary">
    <a class="hero__brand" href="/" aria-label="Juan Villar home">
      <img src="/images/juan-villar-headshot.jpg" alt="" width="44" height="44" decoding="async" />
      <span>Juan Villar</span>
    </a>
    <div class="hero__nav-group">
      <nav class="hero__links">
        {navItems.map(([label, href, labelEs]) => (
          <a href={href} data-i18n={`nav.${label.toLowerCase()}`} data-en={label} data-es={labelEs}>
            {label}
          </a>
        ))}
      </nav>
      <div class="language-toggle" aria-label="Language">
        <button type="button" data-lang-option="en" aria-pressed="true">EN</button>
        <span aria-hidden="true">/</span>
        <button type="button" data-lang-option="es" aria-pressed="false">ES</button>
      </div>
    </div>
  </header>

  <div class="hero__content">
    <div class="hero__copy">
      <p class="hero__role" data-i18n="role">Product designer</p>
      <h1 id="hero-title" class="hero__name">
        <span data-en="HI, I'M JUAN" data-es="HOLA, SOY JUAN">HI, I'M JUAN</span>
      </h1>

      <p class="hero__headline">
        <span data-i18n="headline">
          I design products, systems, and flows where clarity and trust
          <span class="headline-mark-word">
            matter.
            <svg class="mark mark--clarity" viewBox="0 0 160 22" aria-hidden="true">
              <path d="M4 15c28-8 57-10 86-9 22 1 43 4 66 1" />
              <path d="M26 20c36-8 69-11 107-9" />
            </svg>
          </span>
        </span>
      </p>

      <p class="hero__support" data-i18n="support">
        - I partner with teams to turn complexity into simple, confident experiences.
      </p>

      <ul class="hero__chips" aria-label="Focus areas">
        {chips.map(([label, labelEs]) => (
          <li data-en={label} data-es={labelEs}>{label}</li>
        ))}
      </ul>

    </div>

    <div class="hero__map-panel" aria-label="Interactive map of Juan's design focus">
      <div class="map-heading">
        <p>
          <span data-i18n="mapLabelStart">Drag the nodes to interact.</span>
          <span data-i18n="mapLabelEnd">Reset the map when it gets messy.</span>
        </p>
        <button class="map-reset" type="button" data-reset-map>
          <span data-i18n="resetMap">Reset map</span>
        </button>
      </div>

      <div class="flow-map" data-flow-map>
        <svg class="flow-map__lines" aria-hidden="true">
          {connections.map(([from, to]) => (
            <path data-connection data-from={from} data-to={to}></path>
          ))}
        </svg>

        {nodes.map((node) => (
          <article
            class:list={['flow-node', { 'flow-node--active': node.active }]}
            data-node={node.id}
            data-x={node.x}
            data-y={node.y}
            tabindex="0"
            aria-label={`${node.title}: ${node.body}`}
            style={`--x: ${node.x}; --y: ${node.y};`}
          >
            <div class="flow-node__copy">
              <h2 data-node-title data-en={node.title} data-es={node.titleEs}>{node.title}</h2>
              <p data-node-body data-en={node.body} data-es={node.bodyEs}>{node.body}</p>
            </div>
            <div class="flow-node__handle" aria-hidden="true">
              <span></span><span></span><span></span><span></span><span></span><span></span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>

  <a class="hero__scroll-cue" href="#about" aria-label="Scroll to What I do section">
    <svg viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 5v14" />
      <path d="m6 13 6 6 6-6" />
    </svg>
  </a>

  <script>
    import '../scripts/hero-canvas.ts';
  </script>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    overflow: clip;
    padding: clamp(1.25rem, 2.2vw, 2.5rem);
  }

  .hero::before {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    content: '';
    background-image:
      linear-gradient(rgb(16 20 23 / 2%) 1px, transparent 1px),
      linear-gradient(90deg, rgb(16 20 23 / 2%) 1px, transparent 1px);
    background-size: 46px 46px;
    mask-image: linear-gradient(90deg, transparent 0%, black 22%, black 86%, transparent 100%);
  }

  .hero__nav {
    position: relative;
    z-index: 4;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 2.75rem;
    color: var(--color-muted);
    font-size: 0.78rem;
    font-weight: 760;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero__brand {
    display: inline-flex;
    align-items: center;
    gap: clamp(0.55rem, 1vw, 0.8rem);
    color: var(--color-ink);
    font-size: 0.86rem;
    font-weight: 850;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .hero__brand img {
    width: clamp(2.15rem, 3vw, 2.75rem);
    height: clamp(2.15rem, 3vw, 2.75rem);
    flex: 0 0 auto;
    border-radius: 999px;
    object-fit: cover;
    box-shadow: 0 0 0 1px rgb(16 20 23 / 8%);
  }

  .hero__nav-group,
  .hero__links,
  .language-toggle {
    display: flex;
    align-items: center;
  }

  .hero__nav-group {
    gap: clamp(1rem, 2vw, 2rem);
  }

  .hero__links {
    gap: clamp(0.8rem, 1.6vw, 1.45rem);
  }

  .hero__links a[data-i18n='nav.writing'] {
    display: none;
  }

  .hero__links a,
  .language-toggle button,
  .hero__brand {
    transition: color 180ms ease, transform 180ms ease;
  }

  .hero__links a:hover,
  .language-toggle button:hover,
  .hero__brand:hover {
    color: var(--color-blue);
  }

  .language-toggle {
    gap: 0.35rem;
    color: var(--color-muted);
  }

  .language-toggle button {
    min-width: 2rem;
    min-height: 2rem;
    padding: 0;
    border: 0;
    background: transparent;
    color: inherit;
    cursor: pointer;
    font: inherit;
  }

  .language-toggle button[aria-pressed='true'] {
    color: var(--color-blue);
  }

  .hero__content {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(35rem, 1.1fr);
    gap: clamp(2rem, 4vw, 5.25rem);
    align-items: center;
    min-height: calc(100svh - 5.25rem);
    padding-top: clamp(1.5rem, 4vw, 4rem);
  }

  .hero__copy {
    max-width: 52rem;
  }

  .hero__role {
    margin: 0 0 clamp(0.75rem, 1.5vw, 1rem);
    color: #737d88;
    font-size: clamp(0.75rem, 1vw, 1rem);
    font-weight: 520;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .hero__name {
    display: flex;
    flex-wrap: wrap;
    gap: 0.05em 0.18em;
    margin: 0 0 clamp(1rem, 2vw, 1.65rem);
    color: var(--color-blue);
    font-family: var(--font-display);
    font-size: clamp(5.25rem, 9.1vw, 10.75rem);
    font-stretch: condensed;
    font-weight: 900;
    letter-spacing: -0.045em;
    line-height: 0.82;
    white-space: nowrap;
    text-transform: uppercase;
  }

  .hero__headline {
    position: relative;
    max-width: 39rem;
    margin: 0;
    font-family: var(--font-serif);
    font-size: clamp(1.65rem, 2.55vw, 3.05rem);
    font-variation-settings: 'SOFT' 55, 'WONK' 1, 'opsz' 70;
    font-weight: 720;
    letter-spacing: -0.02em;
    line-height: 1.08;
  }

  .hero__headline > span {
    position: relative;
    z-index: 1;
  }

  :global(.headline-mark-word) {
    position: relative;
    display: inline-block;
    white-space: nowrap;
  }

  :global(.mark) {
    position: absolute;
    z-index: 0;
    width: clamp(5.4rem, 12vw, 9.5rem);
    height: auto;
    overflow: visible;
  }

  :global(.mark path) {
    fill: none;
    stroke: var(--color-blue);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 4;
  }

  :global(.mark--clarity) {
    left: -0.08em;
    bottom: -0.2em;
    rotate: -3deg;
  }

  .hero__support {
    max-width: 40rem;
    margin: clamp(1.2rem, 2vw, 1.65rem) 0 0;
    color: var(--color-muted);
    font-size: clamp(1rem, 1.28vw, 1.18rem);
    font-weight: 540;
    line-height: 1.55;
  }

  .hero__chips {
    display: none;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: clamp(1.25rem, 2vw, 1.75rem) 0 0;
    padding: 0;
    list-style: none;
  }

  .hero__chips li {
    display: inline-flex;
    align-items: center;
    min-height: 2.75rem;
    padding: 0.2rem 1.05rem;
    border: 1px solid var(--color-soft);
    border-radius: 999px;
    background: rgb(255 255 255 / 58%);
    color: #29333c;
    box-shadow: 0 1px 4px rgb(17 24 39 / 4%);
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 720;
  }

  .hero__map-panel {
    position: relative;
    align-self: stretch;
    min-height: 39rem;
    padding-top: clamp(0.75rem, 2.5vh, 2rem);
  }

  .map-heading {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin: 0 auto 0.15rem;
    max-width: 56rem;
    color: rgb(102 113 124 / 58%);
    font-family: 'Bradley Hand', 'Segoe Print', 'Comic Sans MS', cursive;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0;
  }

  .map-heading p {
    display: grid;
    gap: 0.18rem;
    margin: 0;
    max-width: 14rem;
    line-height: 1.45;
  }

  .map-heading span {
    display: block;
  }

  .map-reset {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.4rem;
    padding: 0.25rem 0.9rem;
    border: 1px solid var(--color-soft);
    border-radius: 999px;
    background: rgb(255 255 255 / 72%);
    color: rgb(52 65 76 / 62%);
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0;
  }

  .map-reset:hover {
    border-color: var(--color-blue);
    color: var(--color-blue);
  }

  .flow-map {
    position: relative;
    min-height: clamp(29rem, 56vh, 39rem);
    isolation: isolate;
  }

  .flow-map__lines {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
    pointer-events: none;
  }

  .flow-map__lines path {
    fill: none;
    stroke: #aeb9c1;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.2;
    transition: opacity 160ms cubic-bezier(0.23, 1, 0.32, 1), stroke 160ms cubic-bezier(0.23, 1, 0.32, 1), stroke-width 160ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .flow-map__lines path.is-active-connection {
    stroke: rgb(15 92 255 / 52%);
    stroke-width: 2.45;
  }

  .flow-map__lines path.is-dimmed {
    opacity: 0.32;
  }

  .flow-map__lines path.is-connected {
    opacity: 1;
    stroke: rgb(15 92 255 / 72%);
    stroke-width: 2.8;
  }

  .flow-node {
    --node-glow: rgb(17 24 39 / 8%);
    --node-glow-soft: rgb(17 24 39 / 5%);
    --node-interaction-glow: rgb(17 24 39 / 12%);
    --node-interaction-glow-soft: rgb(17 24 39 / 8%);
    position: absolute;
    left: calc(var(--x) * 1%);
    top: calc(var(--y) * 1%);
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.7rem;
    width: clamp(12.6rem, 16vw, 15.5rem);
    min-height: 6.6rem;
    padding: 0.82rem 1rem 0.8rem;
    border: 1px solid var(--color-soft);
    border-radius: 0.95rem;
    background: rgb(255 255 255 / 78%);
    box-shadow: 0 18px 50px var(--node-glow), 0 2px 8px var(--node-glow-soft);
    cursor: grab;
    touch-action: none;
    user-select: none;
    transition: border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
  }

  .flow-node:hover,
  .flow-node:focus-visible {
    border-color: #a7b4bf;
    box-shadow: 0 22px 56px var(--node-interaction-glow), 0 4px 14px var(--node-interaction-glow-soft);
    transform: translateY(-2px);
  }

  .flow-node[data-node='flows'] {
    --node-interaction-glow: rgb(0 174 180 / 18%);
    --node-interaction-glow-soft: rgb(0 174 180 / 10%);
  }

  .flow-node[data-node='systems'] {
    --node-interaction-glow: rgb(255 184 0 / 18%);
    --node-interaction-glow-soft: rgb(255 184 0 / 10%);
  }

  .flow-node[data-node='interfaces'] {
    --node-interaction-glow: rgb(255 91 128 / 16%);
    --node-interaction-glow-soft: rgb(255 91 128 / 9%);
  }

  .flow-node[data-node='trust'] {
    --node-interaction-glow: rgb(120 95 255 / 17%);
    --node-interaction-glow-soft: rgb(120 95 255 / 9%);
  }

  .flow-node[data-node='factory'] {
    --node-interaction-glow: rgb(29 185 84 / 17%);
    --node-interaction-glow-soft: rgb(29 185 84 / 9%);
  }

  .flow-node.is-dragging {
    z-index: 5;
    box-shadow: 0 26px 62px var(--node-interaction-glow), 0 4px 16px var(--node-interaction-glow-soft);
    cursor: grabbing;
    transform: scale(1.025);
  }

  .flow-node--active {
    border: 2px solid var(--color-blue);
    box-shadow: 0 18px 50px var(--node-glow), 0 2px 8px var(--node-glow-soft);
  }

  .flow-node__handle {
    display: grid;
    grid-template-columns: repeat(2, 0.18rem);
    gap: 0.24rem;
    align-content: start;
    padding-top: 0.25rem;
  }

  .flow-node__handle span {
    width: 0.18rem;
    height: 0.18rem;
    border-radius: 50%;
    background: #a8b3bc;
    transition: background-color 160ms cubic-bezier(0.23, 1, 0.32, 1), transform 160ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .flow-node:hover .flow-node__handle span,
  .flow-node:focus-visible .flow-node__handle span,
  .flow-node.is-dragging .flow-node__handle span {
    background: var(--color-blue);
    transform: scale(1.1);
  }

  .flow-node__copy {
    min-width: 0;
    text-align: left;
  }

  .flow-node h2 {
    margin: 0.1rem 0 0.32rem;
    color: #1b252e;
    font-size: clamp(0.98rem, 1.18vw, 1.12rem);
    font-weight: 850;
    letter-spacing: -0.015em;
  }

  .flow-node p {
    margin: 0;
    color: #55626d;
    font-size: clamp(0.68rem, 0.78vw, 0.78rem);
    font-weight: 620;
    line-height: 1.32;
  }

  .hero__scroll-cue {
    position: absolute;
    right: 50%;
    bottom: clamp(1.1rem, 2.2vw, 2rem);
    z-index: 5;
    display: grid;
    place-items: center;
    width: clamp(2.75rem, 4vw, 3.4rem);
    height: clamp(2.75rem, 4vw, 3.4rem);
    border: 1.5px solid var(--color-line);
    border-radius: 50%;
    background: rgb(255 255 255 / 72%);
    color: var(--color-muted);
    box-shadow: 0 10px 34px rgb(17 24 39 / 7%);
    transform: translateX(50%);
    transition:
      border-color 180ms cubic-bezier(0.23, 1, 0.32, 1),
      color 180ms cubic-bezier(0.23, 1, 0.32, 1),
      transform 180ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .hero__scroll-cue:hover {
    border-color: var(--color-blue);
    color: var(--color-blue);
    transform: translateX(50%) translateY(-2px);
  }

  .hero__scroll-cue svg {
    width: 1.2rem;
    height: 1.2rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
    animation: scroll-cue-bounce 1500ms cubic-bezier(0.45, 0, 0.25, 1) infinite;
  }

  @keyframes scroll-cue-bounce {
    0%,
    100% {
      transform: translateY(-2px);
    }

    50% {
      transform: translateY(3px);
    }
  }

  @media (max-width: 1180px) {
    .hero__content {
      grid-template-columns: 1fr;
      gap: 0;
      align-items: start;
    }

    .hero__copy {
      max-width: 58rem;
      padding-top: clamp(1rem, 2vw, 2rem);
    }

    .hero__map-panel {
      display: none;
    }
  }

  @media (max-width: 760px) {
    .hero {
      padding: 1rem;
    }

    .hero__nav {
      align-items: flex-start;
      font-size: 0.7rem;
    }

    .hero__brand {
      gap: 0.55rem;
      font-size: 0.76rem;
    }

    .hero__brand img {
      width: 2rem;
      height: 2rem;
    }

    .hero__nav-group {
      align-items: flex-end;
      flex-direction: column-reverse;
      gap: 0.45rem;
    }

    .hero__links {
      gap: 0.65rem;
    }

    .hero__links a:nth-child(3) {
      display: none;
    }

    .hero__content {
      min-height: auto;
      padding-top: 1.25rem;
    }

    .hero__name {
      font-size: clamp(4.5rem, 23vw, 8.5rem);
      line-height: 0.82;
    }

    .hero__role {
      color: #737d88;
      font-weight: 520;
    }

    .hero__headline {
      font-size: clamp(1.85rem, 9vw, 3rem);
    }

    .hero__support {
      font-size: 1rem;
    }

    .hero__chips li {
      min-height: 2.45rem;
      padding-inline: 0.85rem;
      font-size: 0.86rem;
    }

    .hero__map-panel {
      min-height: 30rem;
      padding-top: 2.25rem;
    }

    .map-heading {
      align-items: flex-start;
      flex-direction: column;
      margin-bottom: 1.25rem;
      font-size: 0.68rem;
    }

    .flow-map {
      min-height: 28rem;
      overflow: hidden;
    }

    .flow-node {
      width: 10.3rem;
      min-height: 7.9rem;
      padding: 0.95rem 0.75rem 0.85rem;
      border-radius: 0.95rem;
    }

    .flow-node[data-node='interfaces'] {
      display: none;
    }

    .flow-node[data-node='factory'] {
      display: none;
    }

  }
</style>
