---
const projects = [
  {
    number: "01",
    tag: "Banking Onboarding & KYC",
    title: "Designing Trust",
    summary:
      "Designing an onboarding experience for regulated financial products, focused on trust, clarity, validation, and user confidence across complex flows.",
    role: "Product Design / UX Strategy / Interaction Design",
    focus: ["Trust", "Onboarding", "Research", "Conversion"],
    variant: "trust",
  },
  {
    number: "02",
    tag: "Information Architecture",
    title: "Structuring Complexity",
    summary:
      "Creating product structure before designing interfaces. Organizing navigation, flows, mental models, and information so complex products become easier to understand.",
    role: "Product Structure / Information Architecture",
    focus: ["Systems Thinking", "Mental Models", "Navigation"],
    variant: "systems",
    reverse: true,
  },
  {
    number: "03",
    tag: "Continuous Mobile Product Improvements",
    title: "Evolving Products",
    summary:
      "Improving an established mobile banking experience through continuous product evolution, refining flows, reducing friction, and supporting long-term product growth.",
    role: "Product Design / Mobile UX / Collaboration",
    focus: ["Iteration", "Mobile UX", "Product Evolution"],
    variant: "evolution",
  },
  {
    number: "04",
    tag: "AI-assisted Product Exploration",
    title: "Exploring What's Next",
    summary:
      "A collection of experiments exploring how AI can accelerate product thinking, prototyping, and decision making while keeping human judgment at the center.",
    role: "AI Workflow / Prototyping / Product Exploration",
    focus: ["AI Workflow", "Rapid Prototypes", "Future Thinking"],
    variant: "ai",
    reverse: true,
  },
];
---

<section class="selected-work" id="work" aria-labelledby="selected-work-title">
  <div class="selected-work__intro">
    <h2 id="selected-work-title">Selected Work</h2>
    <p>
      Product stories across trust, systems, product evolution, and
      AI-assisted design.
    </p>
  </div>

  <div class="selected-work__list" aria-label="Selected product design stories">
    {
      projects.map((project) => (
        <article
          class:list={[
            "work-story",
            `work-story--${project.variant}`,
            { "work-story--reverse": project.reverse },
          ]}
        >
          <div class="work-story__visual" aria-hidden="true">
            <div class="phone-prototype">
              <div class="phone-prototype__screen">
                <div class="prototype-ui">
                  <div class="prototype-ui__status">
                    <span></span>
                    <span></span>
                  </div>
                  <div class="prototype-ui__header">
                    <span></span>
                    <strong>{project.number}</strong>
                  </div>
                  <div class="prototype-ui__body">
                    <span class="prototype-ui__title"></span>
                    <span class="prototype-ui__line"></span>
                    <span class="prototype-ui__line"></span>
                    <div class="prototype-ui__module prototype-ui__module--main">
                      <span></span>
                      <span></span>
                      <span></span>
                    </div>
                    <div class="prototype-ui__flow">
                      <span></span>
                      <span></span>
                      <span></span>
                    </div>
                  </div>
                  <div class="prototype-ui__footer">
                    <span></span>
                  </div>
                </div>
              </div>
              <img
                class="phone-prototype__frame"
                src="/images/apple-iphone-15-black-frame.png"
                alt=""
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>

          <div class="work-story__content">
            <div class="work-story__meta">
              <span>{project.tag}</span>
              <span aria-hidden="true">/</span>
              <span>{project.number}</span>
            </div>

            <h3>{project.title}</h3>
            <p>{project.summary}</p>

            <dl class="work-story__details">
              <div>
                <dt>Role</dt>
                <dd>{project.role}</dd>
              </div>
              <div>
                <dt>Focus</dt>
                <dd>{project.focus.join(", ")}</dd>
              </div>
            </dl>

            <span class="work-story__status">
              Case study coming soon
              <span aria-hidden="true">-&gt;</span>
            </span>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .selected-work {
    position: relative;
    overflow: clip;
    padding: clamp(4.5rem, 8vw, 8rem) clamp(1.25rem, 2.2vw, 2.5rem);
    background:
      linear-gradient(rgb(16 20 23 / 2.4%) 1px, transparent 1px),
      linear-gradient(90deg, rgb(16 20 23 / 2.4%) 1px, transparent 1px),
      linear-gradient(180deg, var(--color-canvas), var(--color-paper));
    background-size:
      46px 46px,
      46px 46px,
      auto;
    border-top: 1px solid var(--color-soft);
  }

  .selected-work__intro {
    display: grid;
    grid-template-columns: minmax(18rem, 0.42fr) minmax(18rem, 0.58fr);
    gap: clamp(2rem, 6vw, 7rem);
    align-items: start;
    margin-bottom: clamp(3rem, 6vw, 6rem);
  }

  .selected-work h2 {
    max-width: 36rem;
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: clamp(3.25rem, 3.1vw, 5rem);
    line-height: 0.9;
    letter-spacing: -0.065em;
    text-transform: uppercase;
  }

  .selected-work__intro p {
    max-width: 38rem;
    margin: 0;
    color: var(--color-muted);
    font-size: clamp(1rem, 1.35vw, 1.28rem);
    font-weight: 400;
    line-height: 1.45;
    letter-spacing: -0.015em;
  }

  .selected-work__list {
    display: grid;
    gap: clamp(3rem, 7vw, 7rem);
  }

  .work-story {
    --story-accent: 15 92 255;
    display: grid;
    grid-template-columns: minmax(17rem, 0.42fr) minmax(20rem, 0.58fr);
    gap: clamp(2.5rem, 7vw, 8rem);
    align-items: center;
    min-height: clamp(34rem, 86svh, 54rem);
  }

  .work-story--reverse .work-story__visual {
    order: 2;
  }

  .work-story--reverse {
    grid-template-columns: minmax(20rem, 0.58fr) minmax(17rem, 0.42fr);
  }

  .work-story--systems {
    --story-accent: 255 184 0;
  }

  .work-story--evolution {
    --story-accent: 29 185 84;
  }

  .work-story--ai {
    --story-accent: 126 87 194;
  }

  .work-story__visual {
    display: grid;
    place-items: center;
    min-width: 0;
    min-height: clamp(31rem, 76svh, 49rem);
  }

  .phone-prototype {
    position: relative;
    width: min(100%, 27rem);
    aspect-ratio: 1419 / 2796;
    filter: drop-shadow(0 34px 50px rgb(17 24 39 / 18%));
    transform: translateY(0);
    transition: transform 260ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .work-story:hover .phone-prototype {
    transform: translateY(-0.45rem) scale(1.012);
  }

  .phone-prototype::before {
    position: absolute;
    inset: -2rem;
    z-index: -1;
    border-radius: 2.75rem;
    background: rgb(var(--story-accent) / 13%);
    filter: blur(32px);
    content: "";
  }

  .phone-prototype__frame {
    position: absolute;
    inset: 0;
    display: block;
    z-index: 2;
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
  }

  .phone-prototype__screen {
    position: absolute;
    inset: 5.2% 7.4% 4.45%;
    z-index: 1;
    overflow: hidden;
    border-radius: 2rem;
    background:
      linear-gradient(rgb(16 20 23 / 5%) 1px, transparent 1px),
      linear-gradient(90deg, rgb(16 20 23 / 5%) 1px, transparent 1px),
      var(--color-paper);
    background-size:
      28px 28px,
      28px 28px,
      auto;
  }

  .prototype-ui {
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    min-height: 100%;
    padding: clamp(3.4rem, 9vw, 4.8rem) clamp(0.9rem, 3vw, 1.2rem)
      clamp(0.9rem, 3vw, 1.2rem);
    color: var(--color-ink);
  }

  .prototype-ui__status,
  .prototype-ui__header,
  .prototype-ui__footer,
  .prototype-ui__flow {
    display: flex;
    align-items: center;
  }

  .prototype-ui__status {
    justify-content: space-between;
    margin-bottom: 1.1rem;
  }

  .prototype-ui__status span {
    display: block;
    width: 3rem;
    height: 0.42rem;
    border-radius: 999px;
    background: rgb(16 20 23 / 16%);
  }

  .prototype-ui__status span:last-child {
    width: 1.4rem;
  }

  .prototype-ui__header {
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .prototype-ui__header span,
  .prototype-ui__title,
  .prototype-ui__line,
  .prototype-ui__footer span {
    display: block;
    border-radius: 999px;
    background: rgb(16 20 23 / 14%);
  }

  .prototype-ui__header span {
    width: 6.4rem;
    height: 0.8rem;
  }

  .prototype-ui__header strong {
    display: grid;
    place-items: center;
    width: 2.4rem;
    min-height: 2.4rem;
    border: 1px solid rgb(var(--story-accent) / 46%);
    border-radius: 999px;
    color: rgb(var(--story-accent));
    font-size: 0.78rem;
    font-weight: 850;
    font-variant-numeric: tabular-nums;
  }

  .prototype-ui__body {
    display: grid;
    align-content: start;
    gap: 0.8rem;
  }

  .prototype-ui__title {
    width: 72%;
    height: 1.15rem;
    background: var(--color-ink);
  }

  .prototype-ui__line {
    width: 88%;
    height: 0.65rem;
  }

  .prototype-ui__line:nth-child(3) {
    width: 58%;
  }

  .prototype-ui__module {
    display: grid;
    gap: 0.7rem;
    margin-top: 1.2rem;
    padding: 1rem;
    border: 1px solid rgb(16 20 23 / 12%);
    border-radius: 1.1rem;
    background: rgb(var(--story-accent) / 8%);
  }

  .prototype-ui__module span {
    display: block;
    height: 2.2rem;
    border-radius: 0.85rem;
    background: rgb(255 255 255 / 82%);
    box-shadow: inset 0 0 0 1px rgb(16 20 23 / 8%);
  }

  .prototype-ui__flow {
    justify-content: space-between;
    gap: 0.55rem;
    margin-top: 1rem;
  }

  .prototype-ui__flow span {
    flex: 1;
    height: 3.2rem;
    border: 1px solid rgb(var(--story-accent) / 28%);
    border-radius: 1rem;
    background: rgb(255 255 255 / 72%);
  }

  .prototype-ui__footer {
    margin-top: 1.2rem;
  }

  .prototype-ui__footer span {
    width: 100%;
    height: 2.7rem;
    background: rgb(var(--story-accent) / 18%);
  }

  .work-story__content {
    display: grid;
    align-content: center;
    justify-items: start;
    min-width: 0;
    min-height: clamp(31rem, 76svh, 49rem);
    padding: clamp(2rem, 5.4vw, 5.6rem);
    border: 1px solid var(--color-line);
    background:
      radial-gradient(
        circle at 18% 14%,
        rgb(var(--story-accent) / 6%),
        transparent 19rem
      ),
      rgb(255 255 255 / 52%);
    box-shadow: 0 24px 80px rgb(17 24 39 / 4%);
  }

  .work-story__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-bottom: clamp(1.25rem, 2.2vw, 2rem);
    color: var(--color-blue);
    font-size: clamp(0.78rem, 0.95vw, 0.92rem);
    font-weight: 850;
    letter-spacing: 0.06em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .work-story__content h3 {
    max-width: 42rem;
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: clamp(3.3rem, 8vw, 8rem);
    line-height: 0.86;
    letter-spacing: -0.07em;
    text-transform: uppercase;
  }

  .work-story__content > p {
    max-width: 39rem;
    margin: clamp(1.25rem, 2vw, 2rem) 0 0;
    color: var(--color-muted);
    font-size: clamp(1rem, 1.28vw, 1.22rem);
    font-weight: 500;
    line-height: 1.48;
    letter-spacing: -0.012em;
  }

  .work-story__details {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1rem, 2vw, 2rem);
    width: 100%;
    margin: clamp(1.6rem, 2.6vw, 2.6rem) 0 0;
    padding: clamp(1rem, 1.6vw, 1.3rem) 0 0;
    border-top: 1px solid var(--color-line);
  }

  .work-story__details div,
  .work-story__details dd {
    min-width: 0;
  }

  .work-story__details dt {
    margin: 0 0 0.4rem;
    color: var(--color-blue);
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .work-story__details dd {
    margin: 0;
    color: var(--color-ink);
    font-size: clamp(0.92rem, 1vw, 1rem);
    font-weight: 680;
    line-height: 1.35;
  }

  .work-story__status {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    min-height: 2.75rem;
    margin-top: clamp(1.6rem, 2.8vw, 2.8rem);
    color: var(--color-ink);
    font-size: clamp(0.95rem, 1vw, 1.08rem);
    font-weight: 850;
    letter-spacing: -0.012em;
  }

  .work-story__status span {
    color: var(--color-blue);
  }

  @media (prefers-reduced-motion: reduce) {
    .phone-prototype,
    .work-story__status,
    .work-story__status span {
      transition: none;
    }

    .work-story:hover .phone-prototype {
      transform: none;
    }
  }

  @media (max-width: 980px) {
    .selected-work__intro,
    .work-story,
    .work-story__details {
      grid-template-columns: 1fr;
    }

    .work-story {
      min-height: auto;
    }

    .work-story__visual,
    .work-story__content {
      min-height: auto;
    }

    .work-story--reverse .work-story__visual {
      order: initial;
    }

    .phone-prototype {
      width: min(100%, 20rem);
    }

    .work-story__content h3 {
      font-size: clamp(3rem, 14vw, 6.5rem);
    }
  }

  @media (max-width: 640px) {
    .selected-work {
      padding-inline: 1rem;
    }

    .work-story {
      gap: 2rem;
    }

    .work-story__content {
      padding: 1.35rem;
    }

    .phone-prototype {
      width: min(100%, 17rem);
    }

    .work-story__content h3 {
      letter-spacing: -0.06em;
    }
  }
</style>
