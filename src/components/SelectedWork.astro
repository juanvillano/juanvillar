---
const chips = ["Product Design", "Banking UX", "KYC", "Shipped", "NDA"];

const details = [
  {
    label: "ROLE",
    value: "Product Designer",
  },
  {
    label: "FOCUS",
    value: "User flows, information architecture, content design",
  },
  {
    label: "STATUS",
    value: "Live",
  },
];
---

<section class="selected-work" id="work" aria-labelledby="selected-work-title">
  <div class="selected-work__inner">
    <header class="selected-work__intro">
      <h2 id="selected-work-title">Latest Work</h2>
      <p>
        Selected product work, ongoing features, and anonymized financial flows
        shaped under real constraints.
      </p>
    </header>

    <article class="case-preview" aria-label="KYC Update flow case preview">
      <ul class="case-preview__chips" aria-label="Project tags">
        {
          chips.map((chip) => (
            <li class:list={{ "case-preview__chip--nda": chip === "NDA" }}>
              {chip === "NDA" && (
                <img src="/icons/lock.svg" alt="" aria-hidden="true" />
              )}
              {chip}
            </li>
          ))
        }
      </ul>

      <div class="case-preview__body">
        <h3>A clearer KYC update flow for clients and the business</h3>
        <p class="case-preview__summary">
          Redesigning a regulated data update flow so clients can review and
          change sensitive information with less friction, clearer guidance, and
          more confidence—while helping the business collect more complete and
          accurate data.
        </p>
      </div>

      <dl class="case-preview__meta" aria-label="Project details">
        {
          details.map((item) => (
            <div>
              <dt>{item.label}</dt>
              <dd class:list={{ "case-preview__status": item.label === "STATUS" }}>
                {item.label === "STATUS" && (
                  <span class="case-preview__status-dot" aria-hidden="true" />
                )}
                {item.value}
              </dd>
            </div>
          ))
        }
      </dl>
    </article>

    <div class="selected-work__visual" aria-hidden="true">
      <img
        class="selected-work__screens"
        src="/images/work/kyc-flow-preview.png"
        alt=""
        loading="lazy"
        decoding="async"
      />
    </div>
  </div>
</section>

<style>
  .selected-work {
    position: relative;
    overflow: clip;
    padding: clamp(4.75rem, 8vw, 8rem) clamp(1.25rem, 3vw, 4.5rem)
      clamp(3rem, 6vw, 5.5rem);
    background:
      linear-gradient(rgb(13 13 89 / 2.2%) 1px, transparent 1px),
      linear-gradient(90deg, rgb(13 13 89 / 2.2%) 1px, transparent 1px),
      linear-gradient(180deg, var(--color-paper), var(--color-canvas));
    background-size:
      46px 46px,
      46px 46px,
      auto;
    border-top: 1px solid rgb(199 208 214 / 64%);
    border-bottom: 1px solid var(--color-line);
  }

  .selected-work__inner {
    display: grid;
    grid-template-columns: minmax(0, 0.46fr) minmax(22rem, 0.54fr);
    gap: clamp(2.5rem, 6vw, 7rem);
    align-items: end;
    width: min(100%, 118rem);
    margin: 0 auto;
  }

  .selected-work__intro {
    grid-column: 1 / -1;
    padding-bottom: clamp(2.5rem, 5vw, 4.25rem);
    border-bottom: 1px solid var(--color-line);
  }

  .selected-work h2 {
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(3rem, 5vw, 5.5rem);
    font-weight: 760;
    line-height: 0.96;
    letter-spacing: -0.06em;
  }

  .selected-work__intro p {
    max-width: 28rem;
    margin: clamp(0.7rem, 1vw, 1rem) 0 0;
    color: var(--color-muted);
    font-size: clamp(0.95rem, 1.1vw, 1.12rem);
    font-weight: 520;
    line-height: 1.35;
    letter-spacing: -0.018em;
  }

  .case-preview {
    display: grid;
    gap: clamp(1.35rem, 2vw, 2rem);
    min-width: 0;
    padding: clamp(1.25rem, 2.2vw, 2rem) 0 0;
  }

  .case-preview__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .case-preview__chips li {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    min-height: 1.7rem;
    padding: 0.26rem 0.68rem;
    border: 1px solid rgb(24 136 0 / 20%);
    border-radius: 999px;
    color: #188800;
    background: rgb(24 136 0 / 10%);
    font-family: var(--font-body);
    font-size: clamp(0.72rem, 0.82vw, 0.88rem);
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
  }

  .case-preview__chips img {
    width: 0.88rem;
    height: 0.88rem;
    display: block;
  }

  .case-preview__body {
    display: grid;
    gap: clamp(1rem, 1.6vw, 1.35rem);
    max-width: 50rem;
  }

  .case-preview h3 {
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 4vw, 4.9rem);
    font-weight: 760;
    line-height: 0.98;
    letter-spacing: -0.065em;
  }

  .case-preview__summary {
    max-width: 42rem;
    margin: 0;
    color: var(--color-muted);
    font-size: clamp(0.98rem, 1.18vw, 1.18rem);
    font-weight: 460;
    line-height: 1.45;
    letter-spacing: -0.018em;
  }

  .case-preview__meta {
    display: grid;
    grid-template-columns: minmax(7rem, 0.4fr) minmax(13rem, 1fr) minmax(
        6rem,
        0.32fr
      );
    gap: clamp(1rem, 2.25vw, 2.6rem);
    max-width: 47rem;
    padding-top: clamp(1.1rem, 1.8vw, 1.5rem);
    margin: 0;
    border-top: 1px solid var(--color-line);
  }

  .case-preview__meta div {
    min-width: 0;
  }

  .case-preview__meta dt {
    margin: 0 0 0.42rem;
    color: #66717c;
    font-family: var(--font-body);
    font-size: clamp(0.68rem, 0.76vw, 0.78rem);
    font-weight: 500;
    letter-spacing: 0.08em;
    line-height: 1;
  }

  .case-preview__meta dd {
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-body);
    font-size: clamp(0.82rem, 0.95vw, 0.98rem);
    font-weight: 760;
    line-height: 1.25;
    letter-spacing: -0.012em;
  }

  .case-preview__status {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
  }

  .case-preview__status-dot {
    position: relative;
    width: 0.68rem;
    height: 0.68rem;
    border-radius: 50%;
    background: #12c83f;
    box-shadow: 0 0 0 0.28rem rgb(18 200 63 / 15%);
  }

  .case-preview__status-dot::after {
    position: absolute;
    inset: -0.28rem;
    border-radius: inherit;
    background: rgb(18 200 63 / 22%);
    content: "";
    animation: selected-work-status-pulse 1.8s ease-out infinite;
  }

  @keyframes selected-work-status-pulse {
    0% {
      opacity: 0.8;
      transform: scale(0.72);
    }

    72%,
    100% {
      opacity: 0;
      transform: scale(1.9);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .case-preview__status-dot::after {
      animation: none;
    }
  }

  .selected-work__visual {
    position: relative;
    display: grid;
    place-items: end center;
    min-height: clamp(24rem, 39vw, 40rem);
    overflow: visible;
  }

  .selected-work__screens {
    width: min(100%, clamp(34rem, 55vw, 70rem));
    max-width: none;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 28px 48px rgb(24 136 0 / 16%));
    transform: translateY(clamp(1rem, 4vw, 4.5rem));
  }

  @media (max-width: 1050px) {
    .selected-work__inner {
      grid-template-columns: 1fr;
      gap: clamp(2rem, 6vw, 4rem);
      align-items: start;
    }

    .selected-work__intro {
      padding-bottom: clamp(2rem, 6vw, 3rem);
    }

    .selected-work__visual {
      min-height: auto;
      place-items: center;
      overflow: hidden;
    }

    .selected-work__screens {
      width: min(44rem, 116vw);
      transform: translateY(0);
    }
  }

  @media (max-width: 720px) {
    .selected-work {
      padding: clamp(3.5rem, 14vw, 5rem) clamp(1.25rem, 5vw, 1.5rem)
        clamp(3rem, 12vw, 4.5rem);
    }

    .selected-work h2 {
      font-size: clamp(2.75rem, 13vw, 4.3rem);
    }

    .selected-work__intro p {
      max-width: none;
      font-size: 0.96rem;
    }

    .case-preview {
      gap: 1.2rem;
    }

    .case-preview__chips {
      gap: 0.4rem;
    }

    .case-preview__chips li {
      font-size: 0.72rem;
    }

    .case-preview h3 {
      font-size: clamp(2.2rem, 11vw, 3.4rem);
    }

    .case-preview__summary {
      font-size: 0.98rem;
    }

    .case-preview__meta {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
</style>
