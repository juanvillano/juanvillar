---
const chips = [
  "Product design",
  "Banking UX",
  "KYC",
  "Regulated flow",
  "Anonymized",
  "Shipped",
];

const details = [
  {
    label: "ROLE",
    value: "Product Designer",
  },
  {
    label: "FOCUS",
    value: "Clarity, validation, trust",
  },
  {
    label: "STATUS",
    value: "Live, anonymized",
  },
];
---

<section class="selected-work" id="work" aria-labelledby="selected-work-title">
  <div class="selected-work__inner">
    <div class="selected-work__copy">
      <header class="selected-work__intro">
        <h2 id="selected-work-title">Latest Work</h2>
        <p>
          Selected product work, ongoing features, and anonymized financial
          flows shaped under real constraints.
        </p>
      </header>

      <article class="case-preview" aria-label="KYC Update Flow case preview">
        <ul class="case-preview__chips" aria-label="Project tags">
          {chips.map((chip) => <li>{chip}</li>)}
        </ul>

        <div class="case-preview__body">
          <p class="case-preview__eyebrow">Banking onboarding and KYC / 01</p>
          <h3>KYC Update Flow</h3>
          <p class="case-preview__summary">
            Simplifying a regulated information update flow so clients can
            complete sensitive data changes with less friction and more
            confidence.
          </p>
        </div>

        <dl class="case-preview__meta" aria-label="Project details">
          {
            details.map((item) => (
              <div>
                <dt>{item.label}</dt>
                <dd>{item.value}</dd>
              </div>
            ))
          }
        </dl>

        <a class="case-preview__link" href="#contact">
          Ask about this project <span aria-hidden="true">-&gt;</span>
        </a>
      </article>
    </div>

    <div class="selected-work__visual" aria-hidden="true">
      <div class="project-phone">
        <div class="project-phone__glow"></div>
        <div class="project-phone__screen">
          <div class="prototype-flow">
            <div class="prototype-flow__status">
              <span></span>
              <span></span>
            </div>

            <div class="prototype-flow__header">
              <span></span>
              <strong>01</strong>
            </div>

            <div class="prototype-flow__copy">
              <span class="prototype-flow__title"></span>
              <span></span>
              <span></span>
            </div>

            <div class="prototype-flow__panel">
              <span></span>
              <span></span>
              <span></span>
            </div>

            <div class="prototype-flow__actions">
              <span></span>
              <span></span>
              <span></span>
            </div>

            <div class="prototype-flow__review">
              <strong></strong>
              <span></span>
              <span></span>
            </div>

            <div class="prototype-flow__button"></div>
          </div>
        </div>
        <img
          class="project-phone__frame"
          src="/images/apple-iphone-15-black-frame.png"
          alt=""
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .selected-work {
    position: relative;
    overflow: clip;
    padding: clamp(4.75rem, 8vw, 8rem) clamp(1.25rem, 3vw, 4.5rem)
      clamp(3rem, 6vw, 5.5rem);
    background:
      linear-gradient(rgb(16 20 23 / 2.2%) 1px, transparent 1px),
      linear-gradient(90deg, rgb(16 20 23 / 2.2%) 1px, transparent 1px),
      linear-gradient(180deg, var(--color-paper), var(--color-canvas));
    background-size:
      46px 46px,
      46px 46px,
      auto;
    border-top: 1px solid rgb(200 208 214 / 64%);
    border-bottom: 1px solid var(--color-line);
  }

  .selected-work__inner {
    display: grid;
    grid-template-columns: minmax(0, 0.57fr) minmax(21rem, 0.43fr);
    gap: clamp(2.5rem, 7vw, 7.5rem);
    align-items: end;
    width: min(100%, 118rem);
    margin: 0 auto;
  }

  .selected-work__copy {
    display: grid;
    gap: clamp(3rem, 6vw, 6rem);
    min-width: 0;
  }

  .selected-work__intro {
    max-width: 58rem;
  }

  .selected-work h2 {
    margin: 0;
    color: #06065c;
    font-family: var(--font-display);
    font-size: clamp(3.25rem, 5vw, 6.75rem);
    font-weight: 900;
    line-height: 0.82;
    letter-spacing: -0.055em;
    text-transform: uppercase;
  }

  .selected-work__intro p {
    max-width: 48rem;
    margin: clamp(0.65rem, 1.1vw, 0.95rem) 0 0;
    color: var(--color-muted);
    font-size: clamp(1rem, 1.25vw, 1.35rem);
    font-weight: 520;
    line-height: 1.25;
    letter-spacing: -0.018em;
  }

  .case-preview {
    display: grid;
    gap: clamp(1.6rem, 2.4vw, 2.4rem);
    padding-bottom: clamp(2rem, 4vw, 3rem);
  }

  .case-preview__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .case-preview__chips li {
    display: inline-flex;
    align-items: center;
    min-height: 1.9rem;
    padding: 0.28rem 0.78rem;
    border: 1px solid rgb(15 92 255 / 28%);
    border-radius: 999px;
    color: var(--color-blue);
    background: rgb(15 92 255 / 7%);
    font-family: var(--font-serif);
    font-size: clamp(0.78rem, 0.9vw, 0.95rem);
    font-weight: 760;
    line-height: 1;
    white-space: nowrap;
  }

  .case-preview__body {
    display: grid;
    gap: clamp(1rem, 1.8vw, 1.55rem);
    max-width: 58rem;
  }

  .case-preview__eyebrow {
    margin: 0;
    color: var(--color-blue);
    font-size: clamp(0.82rem, 0.95vw, 1rem);
    font-weight: 850;
    letter-spacing: 0.1em;
    line-height: 1;
    text-transform: uppercase;
  }

  .case-preview h3 {
    margin: 0;
    color: #06065c;
    font-family: var(--font-serif);
    font-size: clamp(3.15rem, 5.6vw, 7rem);
    font-weight: 850;
    font-variation-settings:
      "SOFT" 0,
      "WONK" 1;
    line-height: 0.9;
    letter-spacing: -0.055em;
  }

  .case-preview__summary {
    max-width: 50rem;
    margin: 0;
    color: var(--color-muted);
    font-size: clamp(1rem, 1.35vw, 1.42rem);
    font-weight: 460;
    line-height: 1.42;
    letter-spacing: -0.018em;
  }

  .case-preview__meta {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1rem, 2.5vw, 3rem);
    max-width: 54rem;
    padding-top: clamp(1.25rem, 2vw, 1.8rem);
    margin: 0;
    border-top: 1px solid var(--color-line);
  }

  .case-preview__meta div {
    min-width: 0;
  }

  .case-preview__meta dt {
    margin: 0 0 0.45rem;
    color: var(--color-blue);
    font-size: clamp(0.72rem, 0.8vw, 0.82rem);
    font-weight: 850;
    letter-spacing: 0.08em;
    line-height: 1;
  }

  .case-preview__meta dd {
    margin: 0;
    color: var(--color-ink);
    font-size: clamp(0.9rem, 1.05vw, 1.05rem);
    font-weight: 760;
    line-height: 1.2;
    letter-spacing: -0.012em;
  }

  .case-preview__link {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    width: max-content;
    color: var(--color-blue);
    font-size: clamp(1rem, 1.15vw, 1.12rem);
    font-weight: 760;
    letter-spacing: -0.01em;
  }

  .case-preview__link span {
    font-size: 1.25em;
    line-height: 1;
    transition: transform 180ms ease;
  }

  .case-preview__link:hover span,
  .case-preview__link:focus-visible span {
    transform: translateX(0.22rem);
  }

  .selected-work__visual {
    position: relative;
    display: grid;
    place-items: end center;
    min-height: clamp(32rem, 56vw, 50rem);
    overflow: visible;
  }

  .project-phone {
    position: relative;
    width: clamp(17rem, 25vw, 30rem);
    aspect-ratio: 1419 / 2796;
    transform: translateY(clamp(4rem, 8vw, 7rem)) rotate(10deg);
    transform-origin: center bottom;
    filter: drop-shadow(0 36px 54px rgb(17 24 39 / 16%));
  }

  .project-phone__glow {
    position: absolute;
    inset: 18% -20% 8%;
    z-index: 0;
    border-radius: 999px;
    background: linear-gradient(
      160deg,
      rgb(15 92 255 / 18%),
      rgb(15 92 255 / 3%)
    );
    filter: blur(36px);
    transform: rotate(-8deg);
  }

  .project-phone__frame {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    pointer-events: none;
  }

  .project-phone__screen {
    position: absolute;
    inset: 5.2% 7.4% 4.45%;
    z-index: 2;
    overflow: hidden;
    border-radius: 6.5% / 3.1%;
    background:
      linear-gradient(rgb(16 20 23 / 5%) 1px, transparent 1px),
      linear-gradient(90deg, rgb(16 20 23 / 5%) 1px, transparent 1px),
      var(--color-paper);
    background-size:
      28px 28px,
      28px 28px,
      auto;
  }

  .prototype-flow {
    display: grid;
    grid-template-rows: auto auto auto auto auto 1fr auto;
    min-height: 100%;
    padding: clamp(3.6rem, 8vw, 4.9rem) clamp(0.9rem, 2vw, 1.2rem)
      clamp(1rem, 2vw, 1.35rem);
  }

  .prototype-flow__status,
  .prototype-flow__header,
  .prototype-flow__actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .prototype-flow__status {
    margin-bottom: clamp(1.3rem, 3vw, 2rem);
  }

  .prototype-flow__status span {
    width: 2.9rem;
    height: 0.42rem;
    border-radius: 999px;
    background: rgb(16 20 23 / 14%);
  }

  .prototype-flow__status span:last-child {
    width: 1.4rem;
  }

  .prototype-flow__header {
    gap: 1rem;
    margin-bottom: clamp(1.7rem, 4vw, 2.6rem);
  }

  .prototype-flow__header span,
  .prototype-flow__copy span,
  .prototype-flow__panel span,
  .prototype-flow__review strong,
  .prototype-flow__review span,
  .prototype-flow__button {
    display: block;
    border-radius: 999px;
    background: rgb(16 20 23 / 12%);
  }

  .prototype-flow__header span {
    width: 42%;
    height: 0.8rem;
  }

  .prototype-flow__header strong {
    display: grid;
    place-items: center;
    width: 2.45rem;
    min-height: 2.45rem;
    border: 1px solid rgb(15 92 255 / 38%);
    border-radius: 999px;
    color: var(--color-blue);
    background: rgb(15 92 255 / 5%);
    font-size: 0.82rem;
    font-weight: 850;
    font-variant-numeric: tabular-nums;
  }

  .prototype-flow__copy {
    display: grid;
    gap: 0.75rem;
    margin-bottom: clamp(1.7rem, 4vw, 2.5rem);
  }

  .prototype-flow__copy .prototype-flow__title {
    width: 70%;
    height: clamp(0.9rem, 2vw, 1.12rem);
    background: var(--color-ink);
  }

  .prototype-flow__copy span:not(.prototype-flow__title) {
    width: 86%;
    height: 0.62rem;
  }

  .prototype-flow__copy span:last-child {
    width: 58%;
  }

  .prototype-flow__panel {
    display: grid;
    gap: 0.7rem;
    padding: clamp(1rem, 2.5vw, 1.45rem);
    margin-bottom: clamp(1.4rem, 3vw, 2rem);
    border: 1px solid rgb(15 92 255 / 13%);
    border-radius: 1rem;
    background: rgb(15 92 255 / 7%);
  }

  .prototype-flow__panel span {
    width: 100%;
    height: clamp(1.25rem, 3vw, 1.65rem);
    background: rgb(255 255 255 / 82%);
    box-shadow: inset 0 0 0 1px rgb(16 20 23 / 5%);
  }

  .prototype-flow__actions {
    gap: 0.55rem;
    margin-bottom: clamp(1.3rem, 3vw, 2rem);
  }

  .prototype-flow__actions span {
    width: 100%;
    height: clamp(1.4rem, 3vw, 1.85rem);
    border: 1px solid rgb(15 92 255 / 24%);
    border-radius: 0.75rem;
    background: rgb(255 255 255 / 62%);
  }

  .prototype-flow__review {
    display: grid;
    gap: 0.65rem;
    align-self: start;
    padding: clamp(1rem, 2.4vw, 1.35rem);
    border: 1px solid rgb(16 20 23 / 9%);
    border-radius: 1rem;
    background: rgb(255 255 255 / 82%);
    box-shadow: 0 16px 34px rgb(17 24 39 / 8%);
  }

  .prototype-flow__review strong {
    width: 56%;
    height: 0.8rem;
    background: var(--color-ink);
  }

  .prototype-flow__review span {
    width: 100%;
    height: 0.56rem;
  }

  .prototype-flow__review span:last-child {
    width: 68%;
  }

  .prototype-flow__button {
    align-self: end;
    height: clamp(1.7rem, 4vw, 2.2rem);
    background: rgb(15 92 255 / 15%);
  }

  @media (max-width: 1050px) {
    .selected-work__inner {
      grid-template-columns: 1fr;
      gap: clamp(1.5rem, 6vw, 4rem);
      align-items: start;
    }

    .selected-work__visual {
      min-height: clamp(22rem, 58vw, 38rem);
      place-items: center;
    }

    .project-phone {
      width: clamp(15rem, 42vw, 24rem);
      transform: translateY(clamp(2rem, 5vw, 4rem)) rotate(8deg);
    }
  }

  @media (max-width: 720px) {
    .selected-work {
      padding: clamp(3.5rem, 14vw, 5rem) clamp(1.25rem, 5vw, 1.5rem)
        clamp(3rem, 12vw, 4.5rem);
    }

    .selected-work__copy {
      gap: clamp(2.4rem, 10vw, 3.5rem);
    }

    .selected-work h2 {
      font-size: clamp(3rem, 17vw, 4.8rem);
    }

    .selected-work__intro p {
      max-width: none;
      font-size: 1rem;
    }

    .case-preview {
      gap: 1.35rem;
      padding-bottom: 1rem;
    }

    .case-preview__chips {
      gap: 0.45rem;
    }

    .case-preview__chips li {
      font-size: 0.78rem;
    }

    .case-preview h3 {
      font-size: clamp(2.7rem, 15vw, 4.4rem);
    }

    .case-preview__summary {
      font-size: 1rem;
    }

    .case-preview__meta {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .selected-work__visual {
      min-height: 24rem;
      margin-top: -1rem;
      overflow: hidden;
    }

    .project-phone {
      width: min(68vw, 18rem);
      transform: translateY(4.2rem) rotate(9deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .case-preview__link span {
      transition: none;
    }
  }
</style>
