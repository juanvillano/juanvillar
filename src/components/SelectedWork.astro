---
type WorkChip = {
  label: string;
  labelEs: string;
  nda?: boolean;
};

type WorkDetail = {
  label: string;
  labelEs: string;
  value: string;
  valueEs: string;
  live?: boolean;
};

type WorkCase = {
  label: string;
  chips: WorkChip[];
  title: string;
  titleEs: string;
  summary: string;
  summaryEs: string;
  href: string;
  details: WorkDetail[];
  image?: string;
  diagram?: boolean;
};

const cases: WorkCase[] = [
  {
    label: "KYC Update flow case preview",
    chips: [
      { label: "Product Design", labelEs: "Diseño de producto" },
      { label: "Banking UX", labelEs: "UX bancaria" },
      { label: "KYC", labelEs: "KYC" },
      { label: "Shipped", labelEs: "Lanzado" },
      { label: "NDA", labelEs: "NDA", nda: true },
    ],
    title: "A clearer KYC update flow for clients and the business",
    titleEs: "Un flujo de actualización KYC más claro para clientes y negocio",
    summary:
      "Redesigning a regulated data update flow so clients can review and change sensitive information with less friction, clearer guidance, and more confidence—while helping the business collect more complete and accurate data.",
    summaryEs:
      "Rediseño de un flujo regulado de actualización de datos para que los clientes puedan revisar y cambiar información sensible con menos fricción, orientación más clara y más confianza, mientras el negocio obtiene datos más completos y precisos.",
    href: "/work/kyc-update-flow/",
    details: [
      {
        label: "ROLE",
        labelEs: "ROL",
        value: "Product Designer",
        valueEs: "Diseñador de producto",
      },
      {
        label: "FOCUS",
        labelEs: "ENFOQUE",
        value: "User flows, information architecture, content design",
        valueEs:
          "Flujos de usuario, arquitectura de información, diseño de contenido",
      },
      {
        label: "STATUS",
        labelEs: "ESTADO",
        value: "Live",
        valueEs: "En vivo",
        live: true,
      },
    ],
    image: "/images/work/kyc-flow-preview.png",
  },
  {
    label: "Digital authentication flow case preview",
    chips: [
      { label: "Product Design", labelEs: "Diseño de producto" },
      { label: "Security UX", labelEs: "UX de seguridad" },
      { label: "Authentication", labelEs: "Autenticación" },
      { label: "Pilot", labelEs: "Piloto" },
      { label: "NDA", labelEs: "NDA", nda: true },
    ],
    title: "A safer digital authentication flow for personal banking users",
    titleEs:
      "Un flujo de autenticación digital más seguro para usuarios de banca personal",
    summary:
      "Designing the user flow and wireframes for an app-based authentication experience that replaces static keys, strengthens transaction security, and supports assisted setup when automatic validation fails.",
    summaryEs:
      "Diseño del flujo de usuario y wireframes para una experiencia de autenticación desde la app que reemplaza claves estáticas, fortalece la seguridad transaccional y contempla asistencia cuando la validación automática falla.",
    href: "/work/digital-authentication-flow/",
    details: [
      {
        label: "ROLE",
        labelEs: "ROL",
        value: "Product Designer",
        valueEs: "Diseñador de producto",
      },
      {
        label: "FOCUS",
        labelEs: "ENFOQUE",
        value: "User flows, wireframes, stakeholder alignment",
        valueEs: "Flujos de usuario, wireframes, alineación con stakeholders",
      },
      {
        label: "STATUS",
        labelEs: "ESTADO",
        value: "Pilot",
        valueEs: "Piloto",
      },
    ],
    diagram: true,
  },
];
---

<section class="selected-work" id="work" aria-labelledby="selected-work-title">
  <div class="selected-work__inner">
    <header class="selected-work__intro">
      <h2 id="selected-work-title" data-en="Latest Work" data-es="Trabajo reciente">
        Latest Work
      </h2>
      <p
        data-en="Selected product work, ongoing features, and anonymized financial flows shaped under real constraints."
        data-es="Trabajo de producto, funcionalidades en curso y flujos financieros anonimizados definidos bajo restricciones reales."
      >
        Selected product work, ongoing features, and anonymized financial flows
        shaped under real constraints.
      </p>
    </header>

    <div class="selected-work__cases">
      {
        cases.map((project) => (
          <div class="selected-work__item">
            <article class="case-preview" aria-label={project.label}>
              <ul class="case-preview__chips" aria-label="Project tags">
                {project.chips.map((chip) => (
                  <li class:list={{ "case-preview__chip--nda": chip.nda }}>
                    {chip.nda && (
                      <img src="/icons/lock.svg" alt="" aria-hidden="true" />
                    )}
                    <span data-en={chip.label} data-es={chip.labelEs}>
                      {chip.label}
                    </span>
                  </li>
                ))}
              </ul>

              <div class="case-preview__body">
                <h3 data-en={project.title} data-es={project.titleEs}>
                  {project.title}
                </h3>
                <p
                  class="case-preview__summary"
                  data-en={project.summary}
                  data-es={project.summaryEs}
                >
                  {project.summary}
                </p>
              </div>

              <dl class="case-preview__meta" aria-label="Project details">
                {project.details.map((item) => (
                  <div>
                    <dt data-en={item.label} data-es={item.labelEs}>
                      {item.label}
                    </dt>
                    <dd
                      class:list={{
                        "case-preview__status": item.label === "STATUS",
                      }}
                    >
                      {item.live && (
                        <span
                          class="case-preview__status-dot"
                          aria-hidden="true"
                        />
                      )}
                      <span data-en={item.value} data-es={item.valueEs}>
                        {item.value}
                      </span>
                    </dd>
                  </div>
                ))}
              </dl>

              <a class="case-preview__link" href={project.href}>
                <span data-en="Read case study" data-es="Leer caso">
                  Read case study
                </span>
                <img src="/icons/move-right.svg" alt="" aria-hidden="true" />
              </a>
            </article>

            <div class="selected-work__visual" aria-hidden="true">
              {project.image ? (
                <img
                  class="selected-work__screens"
                  src={project.image}
                  alt=""
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="selected-work__auth-map">
                  <span
                    data-node="secure"
                    data-en="App-based auth"
                    data-es="Autenticación desde la app"
                  >
                    App-based auth
                  </span>
                  <span
                    data-node="approve"
                    data-en="Secure approval"
                    data-es="Aprobación segura"
                  >
                    Secure approval
                  </span>
                  <span
                    data-node="assist"
                    data-en="Assisted setup"
                    data-es="Configuración asistida"
                  >
                    Assisted setup
                  </span>
                  <span
                    data-node="validate"
                    data-en="Identity validation"
                    data-es="Validación de identidad"
                  >
                    Identity validation
                  </span>
                  <span
                    data-node="fallback"
                    data-en="Fallback path"
                    data-es="Ruta alternativa"
                  >
                    Fallback path
                  </span>
                </div>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .selected-work {
    position: relative;
    overflow: clip;
    padding: clamp(4.75rem, 8vw, 8rem) clamp(1.25rem, 3vw, 4.5rem)
      clamp(3rem, 6vw, 5.5rem);
    background: transparent;
  }

  .selected-work__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: start;
    width: min(100%, 118rem);
    margin: 0 auto;
  }

  .selected-work__intro {
    padding-bottom: clamp(2.5rem, 5vw, 4.25rem);
    border-bottom: 1px solid var(--color-line);
  }

  .selected-work__cases {
    display: grid;
    gap: clamp(4rem, 8vw, 7.5rem);
  }

  .selected-work__item {
    display: grid;
    grid-template-columns: minmax(0, 0.46fr) minmax(22rem, 0.54fr);
    gap: clamp(2.5rem, 6vw, 7rem);
    align-items: center;
    min-width: 0;
  }

  .selected-work__item + .selected-work__item {
    padding-top: clamp(2rem, 4vw, 3.5rem);
  }

  .selected-work h2 {
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(3rem, 5vw, 5.5rem);
    font-weight: 760;
    line-height: 0.96;
    letter-spacing: -0.06em;
  }

  .selected-work__intro p {
    max-width: 28rem;
    margin: clamp(0.7rem, 1vw, 1rem) 0 0;
    color: var(--color-muted);
    font-size: clamp(0.95rem, 1.1vw, 1.12rem);
    font-weight: 520;
    line-height: 1.35;
    letter-spacing: -0.018em;
  }

  .case-preview {
    display: grid;
    gap: clamp(1.35rem, 2vw, 2rem);
    min-width: 0;
    padding: clamp(1.25rem, 2.2vw, 2rem) 0 0;
  }

  .case-preview__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .case-preview__chips li {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    min-height: 1.7rem;
    padding: 0.26rem 0.68rem;
    border: 1px solid rgb(24 136 0 / 20%);
    border-radius: 999px;
    color: #188800;
    background: rgb(24 136 0 / 10%);
    font-family: var(--font-body);
    font-size: clamp(0.72rem, 0.82vw, 0.88rem);
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
  }

  .case-preview__chips img {
    width: 0.88rem;
    height: 0.88rem;
    display: block;
  }

  .case-preview__body {
    display: grid;
    gap: clamp(1rem, 1.6vw, 1.35rem);
    max-width: 50rem;
  }

  .case-preview h3 {
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 4vw, 4.9rem);
    font-weight: 760;
    line-height: 0.98;
    letter-spacing: -0.065em;
  }

  .case-preview__summary {
    max-width: 42rem;
    margin: 0;
    color: var(--color-muted);
    font-size: clamp(0.98rem, 1.18vw, 1.18rem);
    font-weight: 460;
    line-height: 1.45;
    letter-spacing: -0.018em;
  }

  .case-preview__link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    width: fit-content;
    margin-top: -0.2rem;
    color: var(--color-blue);
    font-family: var(--font-body);
    font-size: clamp(0.92rem, 1vw, 1.05rem);
    font-weight: 760;
    line-height: 1;
    text-decoration: none;
    transition:
      color 160ms ease,
      transform 160ms ease;
  }

  .case-preview__link img {
    display: block;
    width: 1.15em;
    height: 1.15em;
    transform: translateY(-0.02em);
  }

  .case-preview__link:is(:hover, :focus-visible) {
    color: var(--color-blue-dark);
    transform: translateX(0.18rem);
  }

  .case-preview__meta {
    display: grid;
    grid-template-columns: minmax(7rem, 0.4fr) minmax(13rem, 1fr) minmax(
        6rem,
        0.32fr
      );
    gap: clamp(1rem, 2.25vw, 2.6rem);
    max-width: 47rem;
    padding-top: clamp(1.1rem, 1.8vw, 1.5rem);
    margin: 0;
    border-top: 1px solid var(--color-line);
  }

  .case-preview__meta div {
    min-width: 0;
  }

  .case-preview__meta dt {
    margin: 0 0 0.42rem;
    color: #66717c;
    font-family: var(--font-body);
    font-size: clamp(0.68rem, 0.76vw, 0.78rem);
    font-weight: 500;
    letter-spacing: 0.08em;
    line-height: 1;
  }

  .case-preview__meta dd {
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-body);
    font-size: clamp(0.82rem, 0.95vw, 0.98rem);
    font-weight: 760;
    line-height: 1.25;
    letter-spacing: -0.012em;
  }

  .case-preview__status {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
  }

  .case-preview__status-dot {
    position: relative;
    width: 0.68rem;
    height: 0.68rem;
    border-radius: 50%;
    background: #12c83f;
    box-shadow: 0 0 0 0.28rem rgb(18 200 63 / 15%);
  }

  .case-preview__status-dot::after {
    position: absolute;
    inset: -0.28rem;
    border-radius: inherit;
    background: rgb(18 200 63 / 22%);
    content: "";
    animation: selected-work-status-pulse 1.8s ease-out infinite;
  }

  @keyframes selected-work-status-pulse {
    0% {
      opacity: 0.8;
      transform: scale(0.72);
    }

    72%,
    100% {
      opacity: 0;
      transform: scale(1.9);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .case-preview__status-dot::after {
      animation: none;
    }
  }

  .selected-work__visual {
    position: relative;
    display: grid;
    place-items: center center;
    min-height: clamp(24rem, 39vw, 40rem);
    overflow: visible;
  }

  .selected-work__screens {
    width: min(100%, clamp(34rem, 55vw, 70rem));
    max-width: none;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 28px 48px rgb(24 136 0 / 16%));
    transform: translateY(clamp(1rem, 4vw, 4.5rem));
  }

  .selected-work__auth-map {
    position: relative;
    width: min(100%, clamp(30rem, 47vw, 58rem));
    aspect-ratio: 1.46;
    filter: drop-shadow(0 26px 46px rgb(15 92 255 / 8%));
  }

  .selected-work__auth-map::before {
    position: absolute;
    inset: 14% 10% 12%;
    background:
      linear-gradient(90deg, transparent 0 16%, #c7d0d6 16% 17%, transparent 17% 48%, #c7d0d6 48% 49%, transparent 49% 82%, #c7d0d6 82% 83%, transparent 83%),
      linear-gradient(0deg, transparent 0 23%, #c7d0d6 23% 24%, transparent 24% 51%, #c7d0d6 51% 52%, transparent 52% 80%, #c7d0d6 80% 81%, transparent 81%);
    border-radius: 2rem;
    content: "";
    opacity: 0.72;
  }

  .selected-work__auth-map span {
    position: absolute;
    display: inline-flex;
    align-items: center;
    min-height: clamp(3.4rem, 5vw, 4.8rem);
    padding: 0.9rem clamp(1rem, 2vw, 1.55rem);
    border: 1px solid rgb(199 208 214 / 76%);
    border-radius: 0.65rem;
    background: rgb(255 255 255 / 86%);
    color: var(--color-ink);
    font-family: var(--font-body);
    font-size: clamp(0.98rem, 1.35vw, 1.55rem);
    font-weight: 820;
    line-height: 1;
    letter-spacing: -0.035em;
    box-shadow: 0 18px 36px rgb(13 13 89 / 8%);
    white-space: nowrap;
  }

  .selected-work__auth-map [data-node="secure"] {
    top: 6%;
    left: 24%;
  }

  .selected-work__auth-map [data-node="approve"] {
    top: 30%;
    right: 0;
  }

  .selected-work__auth-map [data-node="assist"] {
    top: 44%;
    left: 0;
  }

  .selected-work__auth-map [data-node="validate"] {
    right: 10%;
    bottom: 9%;
  }

  .selected-work__auth-map [data-node="fallback"] {
    bottom: 0;
    left: 28%;
    color: var(--color-blue);
    box-shadow: 0 20px 46px rgb(15 92 255 / 12%);
  }

  @media (max-width: 1050px) {
    .selected-work__item {
      grid-template-columns: 1fr;
      gap: clamp(2rem, 6vw, 4rem);
      align-items: start;
    }

    .selected-work__intro {
      padding-bottom: clamp(2rem, 6vw, 3rem);
    }

    .selected-work__visual {
      min-height: auto;
      place-items: center;
      overflow: hidden;
    }

    .selected-work__screens {
      width: min(44rem, 116vw);
      transform: translateY(0);
    }

    .selected-work__auth-map {
      width: min(44rem, 116vw);
    }
  }

  @media (max-width: 720px) {
    .selected-work {
      padding: clamp(3.5rem, 14vw, 5rem) clamp(1.25rem, 5vw, 1.5rem)
        clamp(3rem, 12vw, 4.5rem);
    }

    .selected-work h2 {
      font-size: clamp(2.75rem, 13vw, 4.3rem);
    }

    .selected-work__intro p {
      max-width: none;
      font-size: 0.96rem;
    }

    .case-preview {
      gap: 1.2rem;
    }

    .case-preview__chips {
      gap: 0.4rem;
    }

    .case-preview__chips li {
      font-size: 0.72rem;
    }

    .case-preview h3 {
      font-size: clamp(2.2rem, 11vw, 3.4rem);
    }

    .case-preview__summary {
      font-size: 0.98rem;
    }

    .case-preview__meta {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .selected-work__auth-map {
      aspect-ratio: 1 / 0.9;
    }

    .selected-work__auth-map span {
      min-height: 2.75rem;
      font-size: 0.9rem;
    }
  }
</style>
