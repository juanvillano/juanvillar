---
const emailHref = "mailto:imjuanvillar@gmail.com";
const linkedinHref = "https://www.linkedin.com/in/juan-villar-guillen-79b64735";

const navLinks = [
  ["Work", "#work"],
  ["About", "#about"],
  ["Contact", "#contact"],
];

const contactLinks = [
  ["Email", emailHref],
  ["LinkedIn", linkedinHref],
];
---

<section class="contact-close" id="contact" aria-labelledby="contact-title">
  <div class="contact-close__inner">
    <h2 id="contact-title">
      Bring the messy
      <span>
        flow.
        <svg class="contact-close__mark" viewBox="0 0 160 22" aria-hidden="true">
          <path d="M4 15c28-8 57-10 86-9 22 1 43 4 66 1" />
          <path d="M26 20c36-8 69-11 107-9" />
        </svg>
      </span>
    </h2>

    <div class="contact-close__copy">
      <p>
        If you are working through an unclear product path, a trust-sensitive
        experience, or a design problem that needs structure, send the context.
      </p>

      <div class="contact-close__links" aria-label="Contact links">
        <a href={emailHref}>Email me</a>
        <a href={linkedinHref} target="_blank" rel="noreferrer">LinkedIn</a>
      </div>
    </div>
  </div>
</section>

<footer class="site-footer">
  <div class="site-footer__brand">
    <strong>Juan Villar</strong>
    <p>Product designer growing into design engineering.</p>
  </div>

  <nav class="site-footer__nav" aria-label="Footer navigation">
    {
      navLinks.map(([label, href]) => (
        <a href={href}>{label}</a>
      ))
    }
  </nav>

  <nav class="site-footer__nav" aria-label="Footer contact links">
    {
      contactLinks.map(([label, href]) => (
        <a href={href} target={label === "LinkedIn" ? "_blank" : undefined} rel={label === "LinkedIn" ? "noreferrer" : undefined}>
          {label}
        </a>
      ))
    }
  </nav>

  <p class="site-footer__note">Built with Astro. 2026.</p>
</footer>

<style>
  .contact-close {
    position: relative;
    overflow: clip;
    padding: clamp(4rem, 8vw, 8rem) clamp(1.25rem, 2.2vw, 2.5rem);
    background:
      linear-gradient(rgb(16 20 23 / 2.4%) 1px, transparent 1px),
      linear-gradient(90deg, rgb(16 20 23 / 2.4%) 1px, transparent 1px),
      linear-gradient(180deg, var(--color-paper), var(--color-canvas));
    background-size:
      46px 46px,
      46px 46px,
      auto;
    border-top: 1px solid var(--color-soft);
  }

  .contact-close__inner {
    display: grid;
    grid-template-columns: minmax(18rem, 0.55fr) minmax(18rem, 0.45fr);
    gap: clamp(2rem, 6vw, 7rem);
    align-items: start;
    min-height: clamp(26rem, 42vw, 36rem);
  }

  .contact-close h2 {
    max-width: 42rem;
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: clamp(3.25rem, 3.1vw, 5rem);
    line-height: 0.9;
    letter-spacing: -0.065em;
    text-transform: uppercase;
  }

  .contact-close h2 span {
    position: relative;
    display: inline-block;
  }

  .contact-close__mark {
    position: absolute;
    left: -0.06em;
    right: -0.08em;
    bottom: -0.22em;
    width: 105%;
    height: 0.32em;
    overflow: visible;
    pointer-events: none;
  }

  .contact-close__mark path {
    fill: none;
    stroke: var(--color-blue);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 5;
  }

  .contact-close__copy {
    display: grid;
    gap: clamp(1.5rem, 3vw, 2.5rem);
    padding-top: 0.25rem;
  }

  .contact-close__copy p {
    max-width: 40rem;
    margin: 0;
    color: var(--color-muted);
    font-size: clamp(1.05rem, 1.45vw, 1.42rem);
    font-weight: 600;
    line-height: 1.45;
    letter-spacing: -0.018em;
  }

  .contact-close__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    border-top: 1px solid var(--color-line);
  }

  .contact-close__links a {
    display: inline-flex;
    align-items: center;
    min-height: 3.8rem;
    padding: 0.6rem clamp(1rem, 2vw, 1.4rem);
    border-right: 1px solid var(--color-line);
    color: var(--color-ink);
    font-size: clamp(1rem, 1.2vw, 1.16rem);
    font-weight: 800;
    transition:
      color 180ms cubic-bezier(0.23, 1, 0.32, 1),
      background-color 180ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .contact-close__links a:first-child {
    padding-left: 0;
  }

  .contact-close__links a:last-child {
    border-right: 0;
  }

  .contact-close__links a:hover {
    color: var(--color-blue);
  }

  .site-footer {
    display: grid;
    grid-template-columns: minmax(16rem, 1.15fr) repeat(3, minmax(8rem, 0.35fr));
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: start;
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1.25rem, 2.2vw, 2.5rem);
    border-top: 1px solid var(--color-line);
    background: var(--color-canvas);
    color: var(--color-muted);
  }

  .site-footer__brand {
    display: grid;
    gap: 0.45rem;
  }

  .site-footer__brand strong {
    color: var(--color-ink);
    font-size: clamp(1rem, 1.3vw, 1.2rem);
    font-weight: 880;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .site-footer__brand p,
  .site-footer__note {
    margin: 0;
    font-size: 0.92rem;
    font-weight: 620;
    line-height: 1.35;
  }

  .site-footer__nav {
    display: grid;
    gap: 0.55rem;
  }

  .site-footer__nav a {
    width: fit-content;
    color: var(--color-muted);
    font-size: 0.9rem;
    font-weight: 760;
    transition: color 180ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .site-footer__nav a:hover {
    color: var(--color-blue);
  }

  .site-footer__note {
    justify-self: end;
    text-align: right;
  }

  @media (max-width: 900px) {
    .contact-close__inner,
    .site-footer {
      grid-template-columns: 1fr;
    }

    .contact-close__inner {
      min-height: auto;
    }

    .site-footer__note {
      justify-self: start;
      text-align: left;
    }
  }

  @media (max-width: 640px) {
    .contact-close,
    .site-footer {
      padding-inline: 1rem;
    }

    .contact-close__links {
      display: grid;
    }

    .contact-close__links a {
      border-right: 0;
      border-bottom: 1px solid var(--color-line);
      padding-left: 0;
    }

    .contact-close__links a:last-child {
      border-bottom: 0;
    }
  }
</style>
