---
const services = [
  {
    label: "Core",
    labelEs: "Base",
    title: "End-to-end Design",
    titleEs: "Diseño de producto end-to-end",
    body: "Discovery, Information Architecture, Interaction Design, Prototyping and hand-off",
    bodyEs:
      "Descubrimiento, arquitectura de información, diseño de interacción, prototipado y hand-off.",
    proof: "Systems thinking · Strategy · Handoff",
    proofEs: "Pensamiento sistémico · Estrategia · Handoff",
    accent: "15 92 255",
  },
  {
    label: "Specialty",
    labelEs: "Especialidad",
    title: "Banking & Fintech",
    titleEs: "Banca y fintech",
    body: "Onboarding, verification, account, and regulated product flows - where clarity, trust, and error prevention matter most.",
    bodyEs:
      "Onboarding, verificación, cuentas y flujos regulados donde la claridad, la confianza y la prevención de errores importan más.",
    proof: "8+ years in banking products",
    proofEs: "8+ años en productos bancarios",
    accent: "15 92 255",
    featured: true,
  },
  {
    label: "Evolving",
    labelEs: "Evolución",
    title: "AI-assisted Workflow",
    titleEs: "Flujo de trabajo asistido por IA",
    body: "Using AI to explore directions, prototype faster, analyze patterns, and move from ambiguity to clearer decisions.",
    bodyEs:
      "Uso IA para explorar direcciones, prototipar más rápido, analizar patrones y pasar de la ambigüedad a decisiones más claras.",
    proof: "Prototyping · Pattern analysis",
    proofEs: "Prototipado · Análisis de patrones",
    accent: "126 87 194",
  },
];
---

<section class="what-i-do" id="about" aria-labelledby="what-i-do-title">
  <div class="what-i-do__intro">
    <h2 id="what-i-do-title" data-en="About" data-es="Sobre mí">
      About
    </h2>
    <p
      data-en="I work where product complexity needs to become a clearer path - across flows, structure, and the business context around them."
      data-es="Trabajo donde la complejidad del producto necesita convertirse en un camino más claro: entre flujos, estructura y el contexto de negocio que los rodea."
    >
      I work where product complexity needs to become a clearer path - across
      flows, structure, and the business context around them.
    </p>
  </div>

  <div class="what-i-do__wall" aria-label="Ways Juan can help">
    {
      services.map((service) => (
        <article
          class:list={[
            "what-i-do__item",
            // service.featured && "what-i-do__item--featured",
          ]}
          style={`--item-accent: ${service.accent};`}
        >
          <span
            class="what-i-do__label"
            data-en={service.label}
            data-es={service.labelEs}
          >
            {service.label}
          </span>
          <div class="what-i-do__copy">
            <h3 data-en={service.title} data-es={service.titleEs}>
              {service.title}
            </h3>
            <p data-en={service.body} data-es={service.bodyEs}>
              {service.body}
            </p>
          </div>
          <p
            class="what-i-do__proof"
            data-en={service.proof}
            data-es={service.proofEs}
          >
            {service.proof}
          </p>
        </article>
      ))
    }
  </div>
</section>

<style>
  .what-i-do {
    position: relative;
    overflow: clip;
    padding: clamp(4rem, 8vw, 8rem) clamp(1.25rem, 2.2vw, 2.5rem);
    background:
      linear-gradient(rgb(16 20 23 / 2.8%) 1px, transparent 1px),
      linear-gradient(90deg, rgb(16 20 23 / 2.8%) 1px, transparent 1px),
      linear-gradient(180deg, var(--color-paper), var(--color-canvas));
    background-size:
      46px 46px,
      46px 46px,
      auto;
    border-top: 1px solid var(--color-soft);
  }

  /* .what-i-do__intro {
    display: grid;
    grid-template-columns: minmax(14rem, 0.32fr) minmax(0, 0.42fr) minmax(
        18rem,
        0.26fr
      );
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: start;
    margin-bottom: clamp(2.5rem, 5vw, 5rem);
  } */

  .what-i-do__intro {
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: flex-start;
    justify-content: flex-start;
    margin-bottom: clamp(2.5rem, 5vw, 5rem);
  }

  .what-i-do h2 {
    grid-column: 1 / 2;
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(3rem, 5vw, 5.5rem);
    font-weight: 760;
    line-height: 0.96;
    letter-spacing: -0.06em;
  }

  .what-i-do__intro > p:last-child {
    grid-column: 2 / 4;
    margin: 0;
    color: var(--color-muted);
    font-size: clamp(1rem, 1.35vw, 1.28rem);
    font-weight: 400;
    line-height: 1.45;
    max-width: 50%;
  }

  .what-i-do__wall {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border: 1px solid var(--color-line);
    background: rgb(255 255 255 / 54%);
    box-shadow: 0 24px 80px rgb(17 24 39 / 6%);
  }

  .what-i-do__item {
    display: grid;
    grid-template-rows: auto 1fr auto;
    min-width: 0;
    min-height: clamp(20rem, 27vw, 27rem);
    padding: clamp(1.5rem, 2.9vw, 3.65rem);
    border-right: 1px solid var(--color-line);
    background: rgb(255 255 255 / 38%);
    outline: 1px solid transparent;
    outline-offset: -1px;
    transition:
      border-color 180ms cubic-bezier(0.23, 1, 0.32, 1),
      box-shadow 180ms cubic-bezier(0.23, 1, 0.32, 1),
      outline-color 180ms cubic-bezier(0.23, 1, 0.32, 1),
      transform 180ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .what-i-do__item:last-child {
    border-right: 0;
  }

  .what-i-do__item--featured {
    background:
      linear-gradient(180deg, rgb(15 92 255 / 7%), rgb(15 92 255 / 4%)),
      var(--color-blue-soft);
    border-color: rgb(15 92 255 / 22%);
    box-shadow: inset 0 0 0 1px rgb(15 92 255 / 12%);
  }

  @media (hover: hover) {
    .what-i-do__item:hover {
      z-index: 1;
      border-color: rgb(var(--item-accent) / 54%);
      outline-color: rgb(var(--item-accent) / 72%);
      box-shadow:
        0 24px 70px rgb(var(--item-accent) / 18%),
        0 10px 28px rgb(17 24 39 / 8%);
      transform: translateY(-0.28rem);
    }

    .what-i-do__item:hover .what-i-do__label {
      border-color: rgb(var(--item-accent) / 48%);
      background: rgb(var(--item-accent) / 8%);
      color: rgb(var(--item-accent));
    }
  }

  .what-i-do__label {
    justify-self: start;
    display: inline-flex;
    align-items: center;
    margin-bottom: 1.5rem;
    min-height: 2rem;
    padding: 0.32rem 0.78rem 0.28rem;
    border: 1.5px solid rgb(var(--item-accent) / 72%);
    border-radius: 999px;
    color: var(--color-blue);
    font-size: clamp(0.72rem, 0.85vw, 0.9rem);
    font-weight: 850;
    line-height: 1;
    letter-spacing: 0.075em;
    text-transform: uppercase;
    transition:
      background-color 180ms cubic-bezier(0.23, 1, 0.32, 1),
      border-color 180ms cubic-bezier(0.23, 1, 0.32, 1),
      color 180ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .what-i-do__copy {
    align-self: end;
    display: grid;
    gap: clamp(1.35rem, 2vw, 2rem);
  }

  .what-i-do__copy h3 {
    max-width: 20rem;
    margin: 0;
    color: var(--color-ink);
    font-size: clamp(2rem, 2.8vw, 4rem);
    line-height: 0.95;
    letter-spacing: -0.065em;
  }

  .what-i-do__copy p {
    max-width: 25rem;
    margin: 0;
    color: var(--color-muted);
    font-size: clamp(1rem, 1.25vw, 1.28rem);
    font-weight: 520;
    line-height: 1.45;
  }

  .what-i-do__proof {
    margin: clamp(1.5rem, 2.5vw, 2.25rem) 0 0;
    padding-top: clamp(1rem, 1.6vw, 1.35rem);
    border-top: 1px solid rgb(var(--item-accent) / 22%);
    color: rgb(var(--item-accent));
    font-size: clamp(0.9rem, 1vw, 1rem);
    font-weight: 800;
    line-height: 1.35;
  }

  @media (max-width: 980px) {
    .what-i-do__intro {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .what-i-do h2,
    .what-i-do__intro > p:last-child {
      grid-column: auto;
    }

    .what-i-do__wall {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .what-i-do__item,
    .what-i-do__item:last-child {
      border-right: 1px solid var(--color-line);
    }

    .what-i-do__item:nth-child(2n) {
      border-right: 0;
    }

    .what-i-do__item:nth-child(n + 3) {
      border-top: 1px solid var(--color-line);
    }
  }

  @media (max-width: 640px) {
    .what-i-do {
      padding-inline: 1rem;
    }

    .what-i-do__wall {
      grid-template-columns: 1fr;
    }

    .what-i-do__item {
      min-height: 19rem;
      border-right: 0;
      border-top: 1px solid var(--color-line);
    }

    .what-i-do__item:nth-child(2n),
    .what-i-do__item:last-child {
      border-right: 0;
    }

    .what-i-do__item:first-child {
      border-top: 1px solid var(--color-line);
    }

    .what-i-do__item--featured {
      order: -1;
      border-top: 0;
    }
  }
</style>
