---
const testimonials = [
  {
    quote:
      "Add a coworker review about how the collaboration felt, what problem we worked through, and what changed because of the work.",
    name: "Name",
    role: "Product partner / project context",
    tag: "Collaboration",
  },
  {
    quote:
      "Add a review that speaks to flow clarity, handoffs with engineering, or how a complex product decision became easier to understand.",
    name: "Name",
    role: "Engineering partner / project context",
    tag: "Handoffs",
  },
  {
    quote:
      "Add a review about reliability, trust, business context, or how the work helped the team move with more confidence.",
    name: "Name",
    role: "Stakeholder / project context",
    tag: "Trust",
  },
  {
    quote:
      "Add a review about systems thinking, product maintenance, or improving an experience across states, constraints, and edge cases.",
    name: "Name",
    role: "Design partner / project context",
    tag: "Systems",
  },
];
---

<section class="testimonials" aria-labelledby="testimonials-title">
  <div class="testimonials__intro">
    <h2 id="testimonials-title">People I have worked with</h2>
    <p>
      Notes from collaborators will give this section a human read on how I
      work: the clarity, trust, and structure people experience with me in the
      process.
    </p>
  </div>

  <div class="testimonials__grid" aria-label="Coworker testimonials">
    {
      testimonials.map((testimonial, index) => (
        <figure class="testimonial-card">
          <span class="testimonial-card__number" aria-hidden="true">
            {String(index + 1).padStart(2, "0")}
          </span>
          <blockquote>
            <p>{testimonial.quote}</p>
          </blockquote>
          <figcaption>
            <strong>{testimonial.name}</strong>
            <span>{testimonial.role}</span>
          </figcaption>
          <span class="testimonial-card__tag">{testimonial.tag}</span>
        </figure>
      ))
    }
  </div>
</section>

<style>
  .testimonials {
    position: relative;
    overflow: clip;
    padding: clamp(4rem, 8vw, 8rem) clamp(1.25rem, 2.2vw, 2.5rem);
    background:
      linear-gradient(rgb(16 20 23 / 2.4%) 1px, transparent 1px),
      linear-gradient(90deg, rgb(16 20 23 / 2.4%) 1px, transparent 1px),
      linear-gradient(180deg, var(--color-paper), var(--color-canvas));
    background-size:
      46px 46px,
      46px 46px,
      auto;
    border-top: 1px solid var(--color-soft);
  }

  .testimonials__intro {
    display: grid;
    grid-template-columns: minmax(18rem, 0.42fr) minmax(18rem, 0.58fr);
    gap: clamp(2rem, 6vw, 7rem);
    align-items: start;
    margin-bottom: clamp(2.5rem, 5vw, 5rem);
  }

  .testimonials h2 {
    max-width: 36rem;
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: clamp(3.25rem, 3.1vw, 5rem);
    line-height: 0.9;
    letter-spacing: -0.065em;
    text-transform: uppercase;
  }

  .testimonials__intro p {
    max-width: 44rem;
    margin: 0;
    color: var(--color-muted);
    font-size: clamp(1rem, 1.35vw, 1.28rem);
    font-weight: 400;
    line-height: 1.45;
    letter-spacing: -0.015em;
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border: 1px solid var(--color-line);
    background: rgb(255 255 255 / 48%);
    box-shadow: 0 24px 80px rgb(17 24 39 / 5%);
  }

  .testimonial-card {
    position: relative;
    display: grid;
    grid-template-rows: auto 1fr auto auto;
    min-height: clamp(20rem, 27vw, 29rem);
    gap: clamp(1rem, 2vw, 1.6rem);
    margin: 0;
    padding: clamp(1.1rem, 2.4vw, 2rem);
    border-bottom: 1px solid var(--color-line);
    color: var(--color-ink);
  }

  .testimonial-card:nth-child(odd) {
    border-right: 1px solid var(--color-line);
  }

  .testimonial-card:nth-last-child(-n + 2) {
    border-bottom: 0;
  }

  .testimonial-card__number {
    justify-self: end;
    display: grid;
    place-items: center;
    width: 3.35rem;
    min-height: 3.35rem;
    border: 1px solid var(--color-line);
    color: var(--color-blue);
    font-size: 0.86rem;
    font-weight: 850;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.04em;
  }

  .testimonial-card blockquote {
    align-self: end;
    margin: 0;
  }

  .testimonial-card blockquote p {
    max-width: 44rem;
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(1.35rem, 2vw, 2.2rem);
    font-weight: 720;
    line-height: 1.12;
    letter-spacing: -0.035em;
  }

  .testimonial-card figcaption {
    display: grid;
    gap: 0.25rem;
    color: var(--color-muted);
    font-size: clamp(0.9rem, 1vw, 1rem);
    line-height: 1.35;
  }

  .testimonial-card figcaption strong {
    color: var(--color-ink);
    font-size: clamp(0.98rem, 1.05vw, 1.08rem);
    font-weight: 760;
  }

  .testimonial-card__tag {
    justify-self: start;
    border: 1px solid rgb(15 92 255 / 32%);
    border-radius: 999px;
    padding: 0.42rem 0.7rem;
    color: var(--color-blue);
    font-size: 0.76rem;
    font-weight: 760;
    letter-spacing: 0.04em;
    line-height: 1;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .testimonials__intro,
    .testimonials__grid {
      grid-template-columns: 1fr;
    }

    .testimonial-card,
    .testimonial-card:nth-child(odd),
    .testimonial-card:nth-last-child(-n + 2) {
      border-right: 0;
      border-bottom: 1px solid var(--color-line);
    }

    .testimonial-card:last-child {
      border-bottom: 0;
    }
  }

  @media (max-width: 640px) {
    .testimonials {
      padding-inline: 1rem;
    }

    .testimonial-card {
      min-height: 18rem;
    }
  }
</style>
