---
const testimonials = [
  {
    quote:
      "As a colleague, I always saw him as an approachable leader with a strong ethical sense that very few people possess. He is a capable and innovative professional, and I always admired his ability to adapt to change.\n\nAs a person, Juan is a man of strong values: he supports and defends those around him, and he is someone you can turn to for advice. Any team that has Juan Fernando among its members can be confident of achieving exceptional results.",
    quoteEs:
      "Como colega, siempre lo vi como un líder cercano, con un fuerte sentido ético que muy pocas personas poseen. Es un profesional capaz e innovador, y siempre admiré su habilidad para adaptarse al cambio.\n\nComo persona, Juan es un hombre de valores sólidos: apoya y defiende a quienes lo rodean, y es alguien a quien puedes acudir por consejo. Cualquier equipo que tenga a Juan Fernando entre sus miembros puede confiar en lograr resultados excepcionales.",
    name: "Oscar Martínez",
    nameEs: "Oscar Martínez",
    role: "Senior iOS Developer",
    roleEs: "Desarrollador iOS senior",
    avatar: "/images/testimonials/oscar-martinez.png",
    tags: [
      ["Innovation", "Innovación"],
      ["Leadership", "Liderazgo"],
      ["Trust", "Confianza"],
    ],
  },
  {
    quote:
      "What stands out most about Juan is not only his talent as a designer, but also the wonderful person he is. Working with him is easy: he listens, suggests ideas, improves upon them, and always strives for the best possible outcome. He has a keen eye for detail and a user-centric mindset.",
    quoteEs:
      "Lo que más destaca de Juan no es solo su talento como diseñador, sino también la calidad de persona que es. Trabajar con él es fácil: escucha, propone, mejora ideas y siempre busca el mejor resultado posible. Tiene un ojo muy fino para el detalle y una mentalidad centrada en el usuario. Es el tipo de compañero que cualquier equipo quisiera tener.",
    name: "Byron Gonzalez",
    nameEs: "Byron Gonzalez",
    role: "User Experience Designer",
    roleEs: "Diseñador de experiencia de usuario",
    avatar: "/images/testimonials/byron-gonzalez.png",
    tags: [
      ["Collaboration", "Colaboración"],
      ["User-centered", "Centrado en usuario"],
      ["Detail", "Detalle"],
    ],
  },
];

const getInitials = (name: string) =>
  name
    .split(" ")
    .filter(Boolean)
    .slice(0, 2)
    .map((part) => part[0])
    .join("")
    .toUpperCase();
---

<section class="testimonials" aria-labelledby="testimonials-title">
  <div class="testimonials__intro">
    <h2
      id="testimonials-title"
      data-en="People I've worked with say"
      data-es="Lo que dicen quienes han trabajado conmigo"
    >
      People I've worked with say
    </h2>
  </div>

  <div
    class="testimonials__grid"
    aria-label="Coworker testimonials"
    data-testimonials-track
  >
    {
      testimonials.map((testimonial) => (
        <figure class="testimonial-card">
          <blockquote>
            <p data-en={testimonial.quote} data-es={testimonial.quoteEs}>
              {testimonial.quote}
            </p>
          </blockquote>
          <div class="testimonial-card__tags" aria-label="Review themes">
            {testimonial.tags.map((tag) => (
              <span class="testimonial-card__tag" data-en={tag[0]} data-es={tag[1]}>
                {tag[0]}
              </span>
            ))}
          </div>
          <figcaption>
            {testimonial.avatar ? (
              <img
                src={testimonial.avatar}
                alt=""
                class="testimonial-card__avatar"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <span class="testimonial-card__avatar testimonial-card__avatar--fallback">
                {getInitials(testimonial.name)}
              </span>
            )}
            <span class="testimonial-card__person">
              <strong data-en={testimonial.name} data-es={testimonial.nameEs ?? testimonial.name}>
                {testimonial.name}
              </strong>
              <span data-en={testimonial.role} data-es={testimonial.roleEs}>
                {testimonial.role}
              </span>
            </span>
          </figcaption>
        </figure>
      ))
    }
  </div>
</section>

<style>
  .testimonials {
    position: relative;
    overflow: clip;
    padding: clamp(4rem, 8vw, 8rem) clamp(1.25rem, 2.2vw, 2.5rem);
    background: transparent;
  }

  .testimonials__intro {
    display: grid;
    grid-template-columns: minmax(18rem, 0.42fr) minmax(18rem, 0.58fr);
    gap: clamp(2rem, 6vw, 7rem);
    align-items: start;
    margin-bottom: clamp(2.5rem, 5vw, 5rem);
  }

  .testimonials h2 {
    max-width: 46rem;
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(3rem, 5vw, 5.5rem);
    font-weight: 760;
    line-height: 0.96;
    letter-spacing: -0.06em;
  }

  .testimonials__intro p {
    max-width: 44rem;
    margin: 0;
    color: var(--color-muted);
    font-size: clamp(1rem, 1.35vw, 1.28rem);
    font-weight: 400;
    line-height: 1.45;
    letter-spacing: -0.015em;
  }

  .testimonials__grid {
    display: flex;
    gap: clamp(1rem, 2vw, 1.75rem);
    margin-inline: calc(clamp(1.25rem, 2.2vw, 2.5rem) * -1);
    padding-inline: clamp(1.25rem, 2.2vw, 2.5rem);
    padding-bottom: 0.75rem;
    overflow-x: auto;
    overscroll-behavior-inline: contain;
    scroll-padding-inline: clamp(1.25rem, 2.2vw, 2.5rem);
    scroll-snap-type: inline mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    cursor: grab;
    user-select: none;
  }

  .testimonials__grid::-webkit-scrollbar {
    display: none;
  }

  .testimonials__grid.is-dragging {
    cursor: grabbing;
    scroll-snap-type: none;
  }

  .testimonials__grid.is-dragging * {
    user-select: none;
  }

  .testimonial-card {
    position: relative;
    flex: 0 0 clamp(24rem, 40vw, 45rem);
    display: grid;
    grid-template-rows: 1fr auto auto;
    min-height: clamp(20rem, 27vw, 29rem);
    gap: clamp(1.1rem, 2vw, 1.65rem);
    margin: 0;
    padding: clamp(1.1rem, 2.4vw, 2rem);
    border: 1px solid var(--color-line);
    background: rgb(255 255 255 / 62%);
    box-shadow: 0 24px 80px rgb(17 24 39 / 5%);
    color: var(--color-ink);
    scroll-snap-align: start;
  }

  .testimonial-card blockquote {
    align-self: start;
    margin: 0;
  }

  .testimonial-card blockquote p {
    max-width: 44rem;
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.5vw, 2rem);
    font-weight: 400;
    line-height: 1.3;
    letter-spacing: -0.025em;
    white-space: pre-line;
  }

  .testimonial-card figcaption {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    color: var(--color-muted);
    font-size: clamp(0.9rem, 1vw, 1rem);
    line-height: 1.35;
  }

  .testimonial-card__person {
    display: grid;
    gap: 0.12rem;
    min-width: 0;
  }

  .testimonial-card figcaption strong {
    color: var(--color-ink);
    font-family: var(--font-serif);
    font-size: clamp(0.8rem, 1.3vw, 1.5rem);
    font-weight: 700;
    letter-spacing: -0.035em;
  }

  .testimonial-card__person > span {
    font-family: var(--font-body);
    font-weight: 500;
  }

  .testimonial-card__avatar {
    width: clamp(2.6rem, 3.6vw, 3.25rem);
    height: clamp(2.6rem, 3.6vw, 3.25rem);
    flex: 0 0 auto;
    border: 1px solid rgb(15 92 255 / 18%);
    border-radius: 50%;
    background: var(--color-blue-soft);
    object-fit: cover;
  }

  .testimonial-card__avatar--fallback {
    display: inline-grid;
    place-items: center;
    color: var(--color-blue);
    font-size: 0.8rem;
    font-weight: 850;
    letter-spacing: 0.04em;
  }

  .testimonial-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    align-self: end;
  }

  .testimonial-card__tag {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgb(15 92 255 / 32%);
    background: var(--color-blue-soft);
    border-radius: 999px;
    padding: 0.38rem 0.7rem 0.34rem;
    color: var(--color-blue);
    font-family: var(--font-body);
    font-size: clamp(0.82rem, 1vw, 0.98rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1;
  }

  @media (max-width: 900px) {
    .testimonials__intro {
      grid-template-columns: 1fr;
    }

    .testimonial-card {
      flex-basis: min(32rem, 86vw);
    }
  }

  @media (max-width: 640px) {
    .testimonials {
      padding-inline: 1rem;
    }

    .testimonials__grid {
      margin-inline: -1rem;
      padding-inline: 1rem;
      scroll-padding-inline: 1rem;
    }

    .testimonial-card {
      flex-basis: 84vw;
      min-height: 18rem;
    }
  }
</style>

<script>
  import "../scripts/testimonials";
</script>
