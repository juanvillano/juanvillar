---
const facts = [
  {
    label: "Focus",
    body: "Product flows, systems, interfaces, and trust-sensitive digital experiences.",
  },
  {
    label: "Stack, learning",
    body: "Figma, design systems, prototyping, HTML, CSS, JavaScript, Astro, and The Odin Project.",
  },
  {
    label: "Industries",
    body: "Banking and fintech, with openness to broader product opportunities.",
  },
  {
    label: "Strengths",
    body: "Systems thinking, business translation, collaboration, reliability, and turning ambiguity into clear product decisions.",
  },
  {
    label: "Availability",
    body: "Open to product design, design engineering growth, collaborations, and selected freelance projects.",
  },
];
---

<section class="about-summary" aria-labelledby="about-summary-title">
  <div class="about-summary__inner">
    <h2 id="about-summary-title">What I do</h2>

    <div class="about-summary__ledger" aria-label="About Juan in brief">
      {
        facts.map((fact, index) => (
          <article class="about-summary__row">
            <h3>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <span aria-hidden="true">/</span>
              {fact.label}
            </h3>
            <p>{fact.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .about-summary {
    position: relative;
    overflow: clip;
    padding: clamp(4rem, 8vw, 8rem) clamp(1.25rem, 2.2vw, 2.5rem);
    background:
      linear-gradient(rgb(16 20 23 / 2.4%) 1px, transparent 1px),
      linear-gradient(90deg, rgb(16 20 23 / 2.4%) 1px, transparent 1px),
      linear-gradient(180deg, var(--color-canvas), var(--color-paper));
    background-size:
      46px 46px,
      46px 46px,
      auto;
    border-top: 1px solid var(--color-soft);
  }

  .about-summary__inner {
    display: grid;
    grid-template-columns: minmax(14rem, 0.32fr) minmax(0, 0.68fr);
    gap: clamp(2rem, 5vw, 6rem);
    align-items: start;
  }

  .about-summary h2 {
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: clamp(3.25rem, 3.1vw, 5rem);
    line-height: 0.9;
    letter-spacing: -0.065em;
    text-transform: uppercase;
  }

  .about-summary__ledger {
    border-top: 1px solid var(--color-line);
    background: rgb(255 255 255 / 40%);
  }

  .about-summary__row {
    display: grid;
    grid-template-columns: minmax(12rem, 0.32fr) minmax(0, 0.68fr);
    gap: clamp(1.25rem, 3vw, 3rem);
    align-items: start;
    padding: clamp(1.2rem, 2.2vw, 2rem) 0;
    border-bottom: 1px solid var(--color-line);
  }

  .about-summary__row h3 {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 0;
    color: var(--color-blue);
    font-size: clamp(0.82rem, 1vw, 0.98rem);
    font-weight: 850;
    letter-spacing: 0.04em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .about-summary__row h3 span:first-child {
    font-variant-numeric: tabular-nums;
  }

  .about-summary__row p {
    max-width: 46rem;
    margin: 0;
    color: var(--color-ink);
    font-size: clamp(1rem, 1.35vw, 1.3rem);
    font-weight: 400;
    line-height: 1.42;
    letter-spacing: -0.015em;
  }

  @media (max-width: 860px) {
    .about-summary__inner,
    .about-summary__row {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .about-summary {
      padding-inline: 1rem;
    }

    .about-summary__row {
      gap: 0.85rem;
    }
  }
</style>
