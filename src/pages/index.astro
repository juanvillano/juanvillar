---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import WhatIDo from '../components/WhatIDo.astro';
import AboutSummary from '../components/AboutSummary.astro';
---

<BaseLayout title="Juan Villar - Product Designer">
  <Hero />
  <WhatIDo />
  <AboutSummary />
  <main class="page-placeholders" aria-label="Future portfolio sections">
    <section id="work" aria-label="Selected work"></section>
    <section id="writing" aria-label="Writing"></section>
    <section id="contact" aria-label="Contact"></section>
  </main>
</BaseLayout>
